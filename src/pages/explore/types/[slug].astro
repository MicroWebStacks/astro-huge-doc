---
import Layout from '@/layout/Layout.astro';
import NotFound from '../../404.astro';
import FacetPage from '@/components/explore/FacetPage.astro';
import {config} from '@/config';
import {getDocumentsFull} from '@/libs/structure-db.js';
import {groupDocumentsByFacet} from '@/libs/explore.js';

export function getStaticPaths() {
    if (config.profile === 'lite' || typeof getDocumentsFull !== 'function') return [];
    return groupDocumentsByFacet(getDocumentsFull(), 'type')
        .map((group) => ({params: {slug: group.slug}, props: {group}}));
}

const groups = config.profile === 'lite' || typeof getDocumentsFull !== 'function'
    ? []
    : groupDocumentsByFacet(getDocumentsFull(), 'type');
const group = Astro.props.group ?? groups.find((entry) => entry.slug === Astro.params.slug);
if (!group) Astro.response.status = 404;
---
{!group && <NotFound message={`Type '${Astro.params.slug ?? ''}' was not found.`} />}
{group && <Layout title={`Type: ${group.label}`} headings={[]}><FacetPage title={group.label} description={`${group.documents.length} concept${group.documents.length === 1 ? '' : 's'} with this type.`} variants={group.variants} documents={group.documents} /></Layout>}
