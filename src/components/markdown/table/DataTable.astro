---
import { getAssetUrl } from '@/libs/structure-db';
import { config } from '@/config';
import MarkdownTable from './MarkdownTable.jsx';

export interface Props {
    item: {
        asset_uid?: string;
        version_id?: string;
        ast?: object;
    };
}

const { item } = Astro.props as Props;
const tableNode = item.ast?.type === 'table' ? item.ast : null;
const asset_url = item.asset_uid ? getAssetUrl(item.asset_uid, item.version_id ?? config.collect.version_id) : null;
---
<MarkdownTable client:load node={tableNode} assetUrl={asset_url} />
