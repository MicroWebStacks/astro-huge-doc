---
import Button from '@/components/markdown/directive/ButtonDirective.astro'
import { getAssetUrl } from '@/libs/structure-db';
import { config } from '@/config';

export interface Props {
  data: {
    title: string;
    url: string;
    uid?: string;
    image?: string;
    features?: string[];
    tags?: string[];};
}

const { data } = Astro.props as Props;

let isSvg = false
let isImg = false
let asseturl = ""
if(data.image){
    asseturl = getAssetUrl(data.image, config.collect.version_id) ?? ""
    if(!asseturl && data.uid){
        // Frontmatter `image:` values are file paths, not asset uids; the
        // collector registers them under <doc-uid>.image-<filename>.
        const fileName = String(data.image).split('/').pop()
        asseturl = getAssetUrl(`${data.uid}.image-${fileName}`, config.collect.version_id) ?? ""
    }
    isSvg = Boolean(asseturl) && data.image.endsWith(".svg")
    isImg = Boolean(asseturl) && !isSvg
}
const url = Object.hasOwn(data,"link")?data.link:`/${data.url}`
let hasFeatures = Object.hasOwn(data,"features") && (data.features.length > 0)
let hasTags = Object.hasOwn(data,"tags") && (data.tags.length > 0)

---
<div class="card meta container">
    <div class="content">
        {hasTags&&
            <div class="tags container">
                {data.tags.map((tag)=>(
                    <div class="tag">{tag}</div>
                ))}
            </div>
        }
        <h1 class="title">{data.title}</h1>
        <div class="itemimage">
            {isSvg&&
                <object data={asseturl} name={data.title} data-alt={data.title} />
            }
            {isImg&&
                <img src={asseturl} title={data.title} alt={data.title} />
            }
        </div>
        {hasFeatures&&
            <ul>
                {data.features.map((feature)=>(
                    <li><div class="check" /><div>{feature}</div></li>
                ))}
            </ul>
        }
    </div>
    <div class="bottom">
        <Button label="Details..." link={url} />
    </div>
</div>

<style>
.card.meta.container{
    display:flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3);
    height:100%;
}
.content{
    width:100%;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
}
.bottom{
    margin-top: auto;
    width:100%;
}
.title{
    width:100%;
    text-align: center;
}
.itemimage{
    width:90%;
}
object{
    pointer-events: none;
    max-height: 100%;
    max-width: 100%;
}
img{
    pointer-events: none;
    max-height: 100%;
    max-width: 100%;
}
ul{
    width:100%;
    margin: 0px;
    margin-top: var(--space-3);
    padding: 0px;
}
li{
    list-style-type: none;
    padding: var(--space-1);
    display: flex;
    align-items: center;
}
.check{
    margin-right: var(--space-1);
    background-color: var(--check-bg-color);
    padding: var(--space-1);
    width:5px;
    height:5px;
    border-radius: 30%;
}
.tags.container{
    display: flex;
    gap:var(--space-1);
}
.tag{
    background-color: var(--tag-bg-color);
    padding: var(--space-1);
    border-radius: var(--radius-sm);
    color: var(--tag-text-color);
}
</style>
