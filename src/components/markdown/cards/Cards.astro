---
import {getDocument, getEntry} from '@/libs/structure-db.js'
import CardMeta from './CardsMeta.astro'
import yaml from 'js-yaml'

export interface Props {
  code: string;
}

const { code } = Astro.props as Props;

let cards: Array<Record<string, any>> = []
let yamlError = ''
try {
    const parsed = yaml.load(code)
    if (Array.isArray(parsed)) {
        cards = parsed
    } else {
        yamlError = 'Cards YAML must be a list.'
    }
} catch (error) {
    yamlError = `Could not parse cards YAML: ${error instanceof Error ? error.message : String(error)}`
    console.warn(yamlError)
}

// The lazy backend parses pages on demand: a card target that was never
// visited has no meta_data (frontmatter image, description, ...) yet, so
// force-load it through getEntry before reading the document row. Plain
// values come back unchanged from the sync backends, so the await is safe.
const entries = await Promise.all(cards.map(async (card) => {
    if (!card?.uid || !getDocument({uid: card.uid})) {
        return null;
    }
    await getEntry({uid: card.uid});
    return getDocument({uid: card.uid});
}));
const resolvedCards = entries
  .map((entry, index) => ({entry, config: cards[index]}))
  .filter(({entry}) => entry);

---
<div class="cards container">
    {
        resolvedCards.map(({entry,config})=>(
            <div class="card" style={`width:${config.width_rem}rem`}>
                {/* title/url/tags are document columns, never meta_data
                    fields; merge them so the card has its heading and link. */}
                <CardMeta data={{title: entry.title, url: entry.url, tags: entry.tags, uid: entry.uid, ...entry.meta_data}} />
            </div>
        ))
    }
</div>
{yamlError && <div class="yaml-error" role="alert">{yamlError}</div>}

<style>
.title{
    width:100%;
    text-align:center;
    
}
.cards.container{
    padding-top: var(--space-3);
    display:flex;
    flex-wrap:wrap;
    gap:var(--space-5);
}
.card{
    background-color: var(--surface-raised-bg);
    box-shadow: var(--shadow-raised);
    border-radius:var(--radius-md);
    width:15rem;
    padding:var(--space-3);
}
.card :global(.paragraph:has(>img)) {
    text-align: center;
}
.yaml-error {
    color: var(--color-error, #b42318);
}
</style>
