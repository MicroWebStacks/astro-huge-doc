---
import Svgicons from '@/components/svgicons.astro';
export interface Props {
  attributes: object;
}

const {attributes} = Astro.props as Props;
const summary = Object.hasOwn(attributes,"summary")?attributes.summary:"Details..."

---
<details class="directive">
  <summary>
    <span>{summary}</span>
    <span class="arrow"><Svgicons filename='rightarrow'/></span>
  </summary>
  <article class="details-body">
    <slot/>
  </article>
</details>

<style>
details{
  --details-standard-width: calc(var(--prose-measure) + var(--space-2) * 2 + var(--space-3) * 2);
  display: block;
  background-color: var(--surface-2-bg);
  border-radius: var(--radius-sm);
  padding:var(--space-2);
  margin-top: var(--space-2);
  margin-bottom: var(--space-2);
  /* Closed and wrapped details keep the standard code/prose column. When an
     open, unwrapped code surface publishes a wider measured need, grow only
     to that size and cap it at the currently available article width. */
  width: min(100%, var(--details-standard-width));
  max-width: 100%;
  box-sizing: border-box;
}
details[open][data-wide-code="true"]{
  width: min(100%, max(var(--details-standard-width), var(--details-content-width, 0px)));
}
details[open] summary {border-radius: var(--radius-sm) var(--radius-sm) 0 0;}

summary{
  border-radius: var(--radius-sm);
  cursor: pointer;
  padding:var(--space-2);
  list-style: none;
  display:flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
  min-width: 0;
}
summary > span:first-child{
  min-width: 0;
  overflow-wrap: anywhere;
}
summary:focus-visible{
  outline: 2px solid var(--front-blue);
  outline-offset: -2px;
}
.details-body{
  background-color: var(--content-bg-color);
  padding: var(--space-3);
  min-width: 0;
  max-width: 100%;
  box-sizing: border-box;
}
.details-body :global(.code-shell:not(.embedded)){
  width: 100%;
}
.arrow{flex: 0 0 auto;}
.arrow :global(svg){
  width:16px;
  height:16px;
  rotate: 90deg;
  transition: rotate .4s ease-in-out;
}
details[open] summary :global(svg){
  rotate: -90deg;
  transition: rotate .4s ease-in-out;
}
</style>
