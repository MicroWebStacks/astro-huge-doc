---
import Svgicons from '@/components/svgicons.astro';
import {extname} from 'path'

export interface Props {
  label: string;
  link: string;
  icon: string;
}

const { label, link, icon=null } = Astro.props as Props;
const external = link.startsWith('http')
let used_icon = icon

if(icon == null){
  if(external){
    used_icon = "new"
  }else if([".zip",".hex"].includes(extname(link))){
    used_icon = "download"
  }
}
---
<div class="container">
  <a href={link} class={`link ${external?"external":""}`} target={external?"_blank":"_self"}>
    <span class="button text">{label}</span>
    {used_icon&&
      <span class="icon"><Svgicons filename={used_icon}/></span>
    }
  </a>
</div>

<style>
.container{
  width:100%;
  display:flex;
  flex-direction: column;
  align-items:center;
}
a{
  text-decoration: none;
  border-style: solid;
  border-width: 1px;
  border-color: var(--button-accent-color);
  padding: var(--space-3);
  border-radius: var(--radius-sm);
  margin:var(--space-3);
  display: flex;
  align-items: center;
  gap:var(--space-2);
}
a:hover{
  box-shadow: var(--shadow-raised);
}
a:focus-visible{
  outline: 2px solid var(--front-blue);
  outline-offset: 2px;
}
.button.text{
  color: var(--button-accent-color);
}
.icon{
  height:1rem;
}
.icon :global(svg){
  fill: var(--button-accent-color);
  width:1rem;
  height:1rem;
}
</style>
