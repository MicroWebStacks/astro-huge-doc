---
import Highlighter from './Highlighter.astro'
import Panzoom from '@/components/panzoom/panzoom.astro'
import PanZoomModal from '@/components/panzoom/panzoommodal.astro'
import SvgIcons from '@/components/svgicons.astro';
import { config } from '@/config.js';
import { getAssetUrl } from '@/libs/structure-db';

export interface Props {
    uid:string;
    code: string;
    language: string;
    params: object;
    meta: object;
    versionId?: string;
}

const {uid, code, language, params, meta, versionId = config.collect.version_id} = Astro.props as Props;
const rendererName = config.diagram?.languages?.[language];
const isClientDiagram = rendererName === 'client';
const diagramAssetUid = `${uid}.svg`;
const diagram_url = isClientDiagram
    ? null
    : getAssetUrl(diagramAssetUid, versionId)
        ?? getAssetUrl(diagramAssetUid, config.collect.version_id)
        ?? getAssetUrl(diagramAssetUid);
const hasDiagram = isClientDiagram || Boolean(diagram_url);
let alt = ""
let title = ""
if(params && (params.length > 0)){
    alt = params[0]
    title = params[0]
}
const modalName = title || uid;
const diagramSourceJson = JSON.stringify(code).replace(/</g, '\\u003c');
const languageLabel = language
    .split(/[-_]+/g)
    .filter(Boolean)
    .map(part => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');

---
{hasDiagram &&
    <div class:list={['diagram-shell', {'client-diagram-shell': isClientDiagram}]} data-code-shell data-uid={uid} data-language={language} data-view="diagram">
        <div class="diagram-toolbar" role="toolbar" aria-label="Diagram controls">
            <span class="toolbar-language">{languageLabel}</span>
            <div class="toolbar-group" aria-label="Diagram view mode">
                <button
                    type="button"
                    class="toolbar-btn"
                    data-action="code"
                    title="Show code"
                    aria-label="Show code"
                    aria-pressed="false">
                    <SvgIcons filename="code" />
                </button>
                <button
                    type="button"
                    class="toolbar-btn"
                    data-action="diagram"
                    title="Show diagram"
                    aria-label="Show diagram"
                    aria-pressed="true">
                    <SvgIcons filename="diagram" />
                </button>
            </div>
            <div class="toolbar-group" aria-label="Code display controls">
                <button
                    type="button"
                    class="toolbar-btn"
                    data-code-action="line-numbers"
                    title="Toggle line numbers"
                    aria-label="Toggle line numbers"
                    aria-pressed="false">
                    <SvgIcons filename="line-numbers" />
                </button>
                <button
                    type="button"
                    class="toolbar-btn"
                    data-code-action="wrap"
                    title="Toggle wrapped lines"
                    aria-label="Toggle wrapped lines"
                    aria-pressed="false">
                    <SvgIcons filename="wrap" />
                </button>
            </div>
            <button
                type="button"
                class="toolbar-btn standalone-btn"
                data-code-action="copy"
                title="Copy code"
                aria-label="Copy code">
                <SvgIcons filename="copy" />
            </button>
            <button
                type="button"
                class="toolbar-btn standalone-btn"
                data-action="expand"
                title="Open full view"
                aria-label="Open full view">
                <SvgIcons filename="full-screen" />
            </button>
        </div>
        {!isClientDiagram && diagram_url &&
            <div class="diagram visible" data-role="diagram" data-uid={uid}>
                <Panzoom src={diagram_url} alt={alt} title={title} meta={meta} hash={uid} showOpenButton={false}/>
            </div>
        }
        {isClientDiagram &&
            <div class="diagram client-diagram-panel visible" data-role="diagram" data-uid={uid}>
                <div class="client-diagram" data-language={language} data-panzoom-root="true" data-uid={uid} data-name={modalName} data-sid={uid}>
                    <div class="client-diagram-output" data-mermaid-output={language === 'mermaid' ? true : undefined} data-plantuml-output={language === 'plantuml' ? true : undefined}></div>
                    <div class="client-diagram-error hidden" data-mermaid-error={language === 'mermaid' ? true : undefined} data-plantuml-error={language === 'plantuml' ? true : undefined} role="status" aria-live="polite"></div>
                    <script type="application/json" data-mermaid-source={language === 'mermaid' ? true : undefined} data-plantuml-source={language === 'plantuml' ? true : undefined} set:html={diagramSourceJson}></script>
                    <PanZoomModal sourceSelector='.client-diagram-output svg' />
                </div>
            </div>
        }
        <div class="code hidden" data-role="code" data-uid={uid}>
            <Highlighter uid={uid} code={code} language={language} params={params} showToolbar={false} />
        </div>
    </div>
}
{!hasDiagram &&
    <div class="code visible standalone-code" data-uid={uid}>
        <Highlighter uid={uid} code={code} language={language} params={params} />
    </div>
}

<style>
.visible{
    display:block;
}
.hidden{
    display:none;
}
.diagram{
    width: 100%;
    box-sizing: border-box;
    background-color: var(--diagram-surface-bg);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
}
.client-diagram-panel{
    background-color: var(--client-diagram-surface-bg);
}
/* Client PlantUML re-renders for the active theme, so its surface and
   fullscreen backdrop do not use the static-diagram light-surface compromise. */
.diagram-shell[data-language="plantuml"]{
    background-color: var(--plantuml-surface-bg);
}
.diagram-shell[data-language="plantuml"] .diagram{
    background-color: var(--plantuml-surface-bg);
    --lightbox-surface-bg: var(--plantuml-surface-bg);
}
.client-diagram{
    padding: var(--space-3);
    --lightbox-surface-bg: var(--client-diagram-surface-bg);
}
.client-diagram-output{
    display: flex;
    justify-content: center;
    width: 100%;
    min-width: min(100%, 20rem);
}
/* Fill the available width but never upscale past the diagram's natural
   size: renderers advertise it as an inline max-width (mermaid does this
   itself, plantuml-render.js adds it), which caps the 100% width below. */
.client-diagram-output :global(svg){
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
}
.client-diagram-error{
    margin: var(--space-3);
    padding: var(--space-3);
    color: var(--chart-error-text-color);
    background: var(--chart-error-bg-color);
    border-left: 3px solid var(--chart-error-accent-color);
    border-radius: var(--radius-sm);
    white-space: pre-wrap;
}
.diagram-shell{
    display: flex;
    flex-direction: column;
    /* Width contract (plans/2026-07/12/diagram-width-contract): the shell
       keeps the prose measure for small diagrams, grows with the diagram's
       natural width (published by the renderer as --diagram-natural-width,
       plus the surface padding and borders around the SVG) up to the full
       content column. Without JS the var defaults to 0px and the shell
       behaves exactly like the old min(100%, 80ch). */
    width: min(100%, max(var(--prose-measure), calc(var(--diagram-natural-width, 0px) + var(--space-3) * 2 + 2px)));
    max-width: 100%;
    margin-top: var(--space-3);
    margin-bottom: var(--space-5);
    box-sizing: border-box;
    background-color: var(--diagram-surface-bg);
    border: 1px solid var(--soft-border-color);
    border-radius: var(--radius-md);
    overflow: hidden;
}
.client-diagram-shell{
    --client-diagram-surface-bg: var(--mermaid-surface-bg);
    background-color: var(--client-diagram-surface-bg);
}
.client-diagram-shell[data-language="plantuml"]{
    --client-diagram-surface-bg: var(--plantuml-surface-bg);
}
.diagram-toolbar{
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 28px;
    padding: 2px var(--space-1);
    background: var(--surface-2-bg);
    border-bottom: 1px solid var(--soft-border-color);
}
.toolbar-language{
    margin-right: auto;
    padding: 0 var(--space-2);
    color: var(--content-color-soft, var(--content-color));
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
}
.toolbar-group{
    display: inline-flex;
    overflow: hidden;
    border: 1px solid var(--soft-border-color);
    border-radius: var(--radius-sm);
}
.toolbar-btn{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 24px;
    padding: 0;
    color: var(--content-color);
    background: transparent;
    border: 0;
    border-radius: 0;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
}
.toolbar-btn:active:not(:disabled){
    transform: translateY(1px);
}
.toolbar-btn:focus-visible{
    /* .toolbar-group clips overflow, so an outset ring on the outer
       buttons would be cut off — inset it and lift above the sibling. */
    outline: 2px solid var(--front-blue);
    outline-offset: -2px;
    position: relative;
    z-index: 1;
}
.standalone-btn{
    border: 1px solid var(--soft-border-color);
    border-radius: var(--radius-sm);
}
.toolbar-btn[data-code-action="copy"]{
    width: auto;
    min-width: 28px;
    padding: 0 var(--space-2);
}
.toolbar-group .toolbar-btn + .toolbar-btn{
    border-left: 1px solid var(--soft-border-color);
}
.toolbar-btn:hover:not(:disabled){
    background: var(--menu-span-hover-color);
}
.toolbar-btn[aria-pressed="true"],
.toolbar-btn[data-copied="true"]{
    background: var(--content-bg-color);
    color: var(--front-blue);
}
.toolbar-btn:disabled{
    opacity: 0.4;
    cursor: default;
}
.diagram-shell[data-view="code"] .toolbar-btn[data-action="expand"]{
    opacity: 0.45;
}
.toolbar-btn :global(svg){
    width: 15px;
    height: 15px;
}
.toolbar-btn :global(svg path),
.toolbar-btn :global(svg circle),
.toolbar-btn :global(svg rect),
.toolbar-btn :global(svg polyline),
.toolbar-btn :global(svg line){
    stroke: currentColor;
}
.toolbar-btn :global(svg path),
.toolbar-btn :global(svg rect){
    fill: currentColor;
}
.toolbar-btn[data-action="diagram"] :global(svg path),
.toolbar-btn[data-action="code"] :global(svg path),
.toolbar-btn[data-code-action="copy"] :global(svg path),
.toolbar-btn[data-code-action="line-numbers"] :global(svg path),
.toolbar-btn[data-code-action="wrap"] :global(svg path){
    fill: none;
}
.toolbar-btn[data-code-action="copy"]::after{
    content: "";
    max-width: 0;
    overflow: hidden;
    white-space: nowrap;
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: max-width 0.16s ease, margin-left 0.16s ease, opacity 0.16s ease;
    opacity: 0;
}
.toolbar-btn[data-code-action="copy"][data-copied="true"]::after{
    content: "Copied";
    max-width: 4.5rem;
    margin-left: var(--space-2);
    opacity: 1;
}
</style>

<script>
/* Width contract for the static (Kroki) diagram path: read the natural
   width out of the loaded SVG document and publish it on the shell as
   --diagram-natural-width (shell growth) plus an inline max-width on the
   <object> (no upscale past natural size), matching the client renderers.
   If the SVG exposes neither a pixel width nor a viewBox, the shell simply
   keeps its prose-measure width. */
const applyStaticDiagramWidth = (shell: HTMLElement) => {
    const object = shell.querySelector<HTMLObjectElement>('[data-role="diagram"] object');
    if (!object) {
        return;
    }

    const publish = () => {
        // The <object> document lives in its own realm, so feature-detect via
        // tagName instead of a cross-realm instanceof check.
        const svgRoot = object.contentDocument?.documentElement;
        if (!svgRoot || svgRoot.tagName.toLowerCase() !== 'svg') {
            return;
        }
        const widthAttr = svgRoot.getAttribute('width') ?? '';
        let width = widthAttr.endsWith('%') ? NaN : Number.parseFloat(widthAttr);
        if (!Number.isFinite(width) || width <= 0) {
            width = (svgRoot as any).viewBox?.baseVal?.width ?? NaN;
        }
        if (!Number.isFinite(width) || width <= 0) {
            return;
        }
        shell.style.setProperty('--diagram-natural-width', `${width}px`);
        object.style.maxWidth = `${width}px`;
    };

    object.addEventListener('load', publish);
    publish();
};

const initDiagramControls = () => {
    const shells = document.querySelectorAll('.diagram-shell[data-uid]');
    shells.forEach(shell => {
        if (shell.getAttribute('data-controls-ready') === 'true') {
            return;
        }

        shell.setAttribute('data-controls-ready', 'true');
        applyStaticDiagramWidth(shell as HTMLElement);

        const diagramDiv = shell.querySelector('[data-role="diagram"]');
        const codeDiv = shell.querySelector('[data-role="code"]');
        const diagramButton = shell.querySelector('button[data-action="diagram"]');
        const codeButton = shell.querySelector('button[data-action="code"]');
        const expandButton = shell.querySelector('button[data-action="expand"]');

        const setView = (view) => {
            const showDiagram = view === 'diagram';
            shell.setAttribute('data-view', view);

            if (diagramDiv) {
                diagramDiv.classList.toggle('visible', showDiagram);
                diagramDiv.classList.toggle('hidden', !showDiagram);
            }

            if (codeDiv) {
                codeDiv.classList.toggle('visible', !showDiagram);
                codeDiv.classList.toggle('hidden', showDiagram);
            }

            if (diagramButton) {
                diagramButton.setAttribute('aria-pressed', String(showDiagram));
            }

            if (codeButton) {
                codeButton.setAttribute('aria-pressed', String(!showDiagram));
            }

            shell.dispatchEvent(new CustomEvent('microwebstacks:code-view-change', {bubbles: true}));
        };

        diagramButton?.addEventListener('click', () => setView('diagram'));
        codeButton?.addEventListener('click', () => setView('code'));
        expandButton?.addEventListener('click', () => {
            if (shell.getAttribute('data-view') !== 'diagram') {
                setView('diagram');
            }

            const modal = shell.querySelector('.modal-background');
            if (modal) {
                modal.dispatchEvent(new CustomEvent('open'));
            }
        });

        setView(shell.getAttribute('data-view') ?? 'diagram');
    });
};

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDiagramControls, false);
} else {
    initDiagramControls();
}
</script>


<script src="./mermaid-render.js" />
<script src="./plantuml-render.js" />
<script src="../../panzoom/panzoom_common.js" />
