---
import Highlighter from './Highlighter.astro'
import Panzoom from '@/components/panzoom/panzoom.astro'
import PanZoomModal from '@/components/panzoom/panzoommodal.astro'
import SvgIcons from '@/components/svgicons.astro';
import { config } from '@/config.js';
import { getAssetUrl } from '@/libs/structure-db';

export interface Props {
    uid:string;
    code: string;
    language: string;
    params: object;
    meta: object;
    versionId?: string;
}

const {uid, code, language, params, meta, versionId = config.collect.version_id} = Astro.props as Props;
const rendererName = config.diagram?.languages?.[language];
const isClientDiagram = rendererName === 'client';
const diagramAssetUid = `${uid}.svg`;
const diagram_url = isClientDiagram
    ? null
    : getAssetUrl(diagramAssetUid, versionId)
        ?? getAssetUrl(diagramAssetUid, config.collect.version_id)
        ?? getAssetUrl(diagramAssetUid);
const hasDiagram = isClientDiagram || Boolean(diagram_url);
let alt = ""
let title = ""
if(params && (params.length > 0)){
    alt = params[0]
    title = params[0]
}
const modalName = title || uid;
const mermaidSourceJson = JSON.stringify(code).replace(/</g, '\\u003c');
const languageLabel = language
    .split(/[-_]+/g)
    .filter(Boolean)
    .map(part => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');

---
{hasDiagram &&
    <div class:list={['diagram-shell', {'mermaid-shell': isClientDiagram}]} data-code-shell data-uid={uid} data-language={language} data-view="diagram">
        <div class="diagram-toolbar" role="toolbar" aria-label="Diagram controls">
            <span class="toolbar-language">{languageLabel}</span>
            <div class="toolbar-group" aria-label="Diagram view mode">
                <button
                    type="button"
                    class="toolbar-btn"
                    data-action="code"
                    title="Show code"
                    aria-label="Show code"
                    aria-pressed="false">
                    <SvgIcons filename="code" />
                </button>
                <button
                    type="button"
                    class="toolbar-btn"
                    data-action="diagram"
                    title="Show diagram"
                    aria-label="Show diagram"
                    aria-pressed="true">
                    <SvgIcons filename="diagram" />
                </button>
            </div>
            <div class="toolbar-group" aria-label="Code display controls">
                <button
                    type="button"
                    class="toolbar-btn"
                    data-code-action="line-numbers"
                    title="Toggle line numbers"
                    aria-label="Toggle line numbers"
                    aria-pressed="false">
                    <SvgIcons filename="line-numbers" />
                </button>
                <button
                    type="button"
                    class="toolbar-btn"
                    data-code-action="wrap"
                    title="Toggle wrapped lines"
                    aria-label="Toggle wrapped lines"
                    aria-pressed="false">
                    <SvgIcons filename="wrap" />
                </button>
            </div>
            <button
                type="button"
                class="toolbar-btn standalone-btn"
                data-code-action="copy"
                title="Copy code"
                aria-label="Copy code">
                <SvgIcons filename="copy" />
            </button>
            <button
                type="button"
                class="toolbar-btn standalone-btn"
                data-action="expand"
                title="Open full view"
                aria-label="Open full view">
                <SvgIcons filename="full-screen" />
            </button>
        </div>
        {!isClientDiagram && diagram_url &&
            <div class="diagram visible" data-role="diagram" data-uid={uid}>
                <Panzoom src={diagram_url} alt={alt} title={title} meta={meta} hash={uid} showOpenButton={false}
                    themeLazy={language === 'plantuml'} versionId={versionId}/>
            </div>
        }
        {isClientDiagram &&
            <div class="diagram mermaid-panel visible" data-role="diagram" data-uid={uid}>
                <div class="mermaid-diagram" data-panzoom-root="true" data-uid={uid} data-name={modalName} data-sid={uid}>
                    <div class="mermaid-output" data-mermaid-output></div>
                    <div class="mermaid-error hidden" data-mermaid-error role="status" aria-live="polite"></div>
                    <script type="application/json" data-mermaid-source set:html={mermaidSourceJson}></script>
                    <PanZoomModal sourceSelector='[data-mermaid-output] svg' />
                </div>
            </div>
        }
        <div class="code hidden" data-role="code" data-uid={uid}>
            <Highlighter uid={uid} code={code} language={language} params={params} showToolbar={false} />
        </div>
    </div>
}
{!hasDiagram &&
    <div class="code visible standalone-code" data-uid={uid}>
        <Highlighter uid={uid} code={code} language={language} params={params} />
    </div>
}

<style>
.visible{
    display:block;
}
.hidden{
    display:none;
}
.diagram{
    width: 100%;
    box-sizing: border-box;
    background-color: var(--diagram-surface-bg);
    border-radius: 0 0 8px 8px;
}
.mermaid-panel{
    background-color: var(--mermaid-surface-bg);
}
/* PlantUML is theme-aware (dark baked at build, light swapped lazily), so its
   surface + fullscreen backdrop follow the active theme instead of the
   "always light" --diagram-surface-bg compromise. */
.diagram-shell[data-language="plantuml"]{
    background-color: var(--plantuml-surface-bg);
}
.diagram-shell[data-language="plantuml"] .diagram{
    background-color: var(--plantuml-surface-bg);
    --lightbox-surface-bg: var(--plantuml-surface-bg);
}
.mermaid-diagram{
    padding: 10px;
    --lightbox-surface-bg: var(--mermaid-surface-bg);
}
.mermaid-output{
    display: flex;
    justify-content: center;
    width: 100%;
    min-width: min(100%, 20rem);
}
.mermaid-output :global(svg){
    display: block;
    width: 100%;
    height: auto;
}
.mermaid-error{
    margin: 10px;
    padding: 12px;
    color: var(--chart-error-text-color);
    background: var(--chart-error-bg-color);
    border-left: 3px solid var(--chart-error-accent-color);
    border-radius: 6px;
    white-space: pre-wrap;
}
.diagram-shell{
    display: flex;
    flex-direction: column;
    width: min(100%, 80ch);
    max-width: 100%;
    margin-top: 12px;
    margin-bottom: 20px;
    box-sizing: border-box;
    background-color: var(--diagram-surface-bg);
    border: 1px solid var(--soft-border-color);
    border-radius: 8px;
    overflow: hidden;
}
.mermaid-shell{
    background-color: var(--mermaid-surface-bg);
}
.diagram-toolbar{
    display: flex;
    align-items: center;
    gap: 6px;
    min-height: 28px;
    padding: 2px 5px;
    background: var(--surface-2-bg);
    border-bottom: 1px solid var(--soft-border-color);
}
.toolbar-language{
    margin-right: auto;
    padding: 0 8px;
    color: var(--content-color-soft, var(--content-color));
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
}
.toolbar-group{
    display: inline-flex;
    overflow: hidden;
    border: 1px solid var(--soft-border-color);
    border-radius: 6px;
}
.toolbar-btn{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 24px;
    padding: 0;
    color: var(--content-color);
    background: transparent;
    border: 0;
    border-radius: 0;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
}
.toolbar-btn:active:not(:disabled){
    transform: translateY(1px);
}
.standalone-btn{
    border: 1px solid var(--soft-border-color);
    border-radius: 6px;
}
.toolbar-btn[data-code-action="copy"]{
    width: auto;
    min-width: 28px;
    padding: 0 8px;
}
.toolbar-group .toolbar-btn + .toolbar-btn{
    border-left: 1px solid var(--soft-border-color);
}
.toolbar-btn:hover:not(:disabled){
    background: var(--menu-span-hover-color);
}
.toolbar-btn[aria-pressed="true"],
.toolbar-btn[data-copied="true"]{
    background: var(--content-bg-color);
    color: var(--front-blue);
}
.toolbar-btn:disabled{
    opacity: 0.4;
    cursor: default;
}
.diagram-shell[data-view="code"] .toolbar-btn[data-action="expand"]{
    opacity: 0.45;
}
.toolbar-btn :global(svg){
    width: 15px;
    height: 15px;
}
.toolbar-btn :global(svg path),
.toolbar-btn :global(svg circle),
.toolbar-btn :global(svg rect),
.toolbar-btn :global(svg polyline),
.toolbar-btn :global(svg line){
    stroke: currentColor;
}
.toolbar-btn :global(svg path),
.toolbar-btn :global(svg rect){
    fill: currentColor;
}
.toolbar-btn[data-action="diagram"] :global(svg path),
.toolbar-btn[data-action="code"] :global(svg path),
.toolbar-btn[data-code-action="copy"] :global(svg path),
.toolbar-btn[data-code-action="line-numbers"] :global(svg path),
.toolbar-btn[data-code-action="wrap"] :global(svg path){
    fill: none;
}
.toolbar-btn[data-code-action="copy"]::after{
    content: "";
    max-width: 0;
    overflow: hidden;
    white-space: nowrap;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: max-width 0.16s ease, margin-left 0.16s ease, opacity 0.16s ease;
    opacity: 0;
}
.toolbar-btn[data-code-action="copy"][data-copied="true"]::after{
    content: "Copied";
    max-width: 4.5rem;
    margin-left: 6px;
    opacity: 1;
}
</style>

<script>
const initDiagramControls = () => {
    const shells = document.querySelectorAll('.diagram-shell[data-uid]');
    shells.forEach(shell => {
        if (shell.getAttribute('data-controls-ready') === 'true') {
            return;
        }

        shell.setAttribute('data-controls-ready', 'true');

        const diagramDiv = shell.querySelector('[data-role="diagram"]');
        const codeDiv = shell.querySelector('[data-role="code"]');
        const diagramButton = shell.querySelector('button[data-action="diagram"]');
        const codeButton = shell.querySelector('button[data-action="code"]');
        const expandButton = shell.querySelector('button[data-action="expand"]');

        const setView = (view) => {
            const showDiagram = view === 'diagram';
            shell.setAttribute('data-view', view);

            if (diagramDiv) {
                diagramDiv.classList.toggle('visible', showDiagram);
                diagramDiv.classList.toggle('hidden', !showDiagram);
            }

            if (codeDiv) {
                codeDiv.classList.toggle('visible', !showDiagram);
                codeDiv.classList.toggle('hidden', showDiagram);
            }

            if (diagramButton) {
                diagramButton.setAttribute('aria-pressed', String(showDiagram));
            }

            if (codeButton) {
                codeButton.setAttribute('aria-pressed', String(!showDiagram));
            }

            shell.dispatchEvent(new CustomEvent('microwebstacks:code-view-change', {bubbles: true}));
        };

        diagramButton?.addEventListener('click', () => setView('diagram'));
        codeButton?.addEventListener('click', () => setView('code'));
        expandButton?.addEventListener('click', () => {
            if (shell.getAttribute('data-view') !== 'diagram') {
                setView('diagram');
            }

            const modal = shell.querySelector('.modal-background');
            if (modal) {
                modal.dispatchEvent(new CustomEvent('open'));
            }
        });

        setView(shell.getAttribute('data-view') ?? 'diagram');
    });
};

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDiagramControls, false);
} else {
    initDiagramControls();
}
</script>


<script src="./mermaid-render.js" />
<script src="../../panzoom/panzoom_common.js" />
