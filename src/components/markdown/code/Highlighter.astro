---
import Svgicons from '@/components/svgicons.astro';
import {codeToHtml} from './highlighter.js'

export interface Props {
    uid: string;
    code: string;
    language: string;
    params: object;
}

const { uid, code, language, params } = Astro.props as Props;

const html = await codeToHtml(code, { lang: language, theme:'dark-plus' })

---
<div class="highlighter container" data-uid={uid}>
    <Fragment set:html={html}></Fragment>
    <button class="copy-btn" data-uid={uid}><Svgicons filename="copy" /></button>
    <span class="copy-message" data-uid={uid}>Copied!</span>
</div>

<style>
.highlighter.container {
    position: relative;
    margin-top: 10px;
    margin-bottom: 20px;
    width: fit-content;
    min-width: 98%;
    border-width: 1px;
    border-style: solid;
    border-color: var(--code-border-color);
}
.copy-btn {
    position: absolute;
    top: 15px;
    right: 5px;
    cursor: pointer;
    display: none;
    background: transparent;
    border-width: 1px;
    border-style: solid;
    border-color: var(--code-btn-border-color);
    border-radius: 3px;
    padding: 5px;
    outline: none;
}
.container:hover .copy-btn {
    display: block;
}

.copy-message {
    display: none;
    position: absolute;
    top: 15px;
    right: 40px;
    background-color: var(--tooltip-bg-color);
    color: var(--tooltip-text-color);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 12px;
    transition: opacity 0.3s;
}
</style>

<style is:global>
pre{
    padding:10px;
}
/* Shiki dual-theme: select the active palette from the CSS variables it
   emitted (--shiki-light / --shiki-dark) based on the resolved theme. */
:root[data-theme="light"] .shiki,
:root[data-theme="light"] .shiki span{
    color: var(--shiki-light);
}
:root[data-theme="light"] .shiki{
    background-color: var(--shiki-light-bg);
}
:root[data-theme="dark"] .shiki,
:root[data-theme="dark"] .shiki span{
    color: var(--shiki-dark);
}
:root[data-theme="dark"] .shiki{
    background-color: var(--shiki-dark-bg);
}
.copy-btn > svg{
  height: 16px;
  width: 16px;
  margin:0px;
  padding-top: 2px;
  padding-left: 2px;
  fill:var(--code-btn-fill-color);
}
</style>

<script>
const buttons = document.querySelectorAll('button.copy-btn');
buttons.forEach(button => {
    button.addEventListener('click', async () => {
        const uid = button.getAttribute('data-uid');
        const message = document.querySelector(`.copy-message[data-uid="${uid}"]`);
        
        try {
            const container = button.closest('.highlighter.container');
            const codeText = container?.querySelector('pre')?.textContent ?? '';
            if (codeText) {
                await navigator.clipboard.writeText(codeText);
                
                message.style.display = 'block';
                setTimeout(() => {
                    message.style.display = 'none';
                }, 1000);
                
            } else {
                console.error('Failed to read code content');
            }
        } catch (error) {
            console.error('Error:', error);
        }
    });
});
</script>
