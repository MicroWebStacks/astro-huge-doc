{
  "scopeName": "source.mermaid",
  "patterns": [
    { "include": "#configDirective" },
    { "include": "#diagramTypes" },
    { "include": "#comments" },
    { "include": "#transitions" },
    { "include": "#strings" },
    { "include": "#variables" }
  ],
  "repository": {
    "configDirective": {
      "name": "meta.directive.config.mermaid",
      "begin": "^\\s*%%(?=\\{)",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.directive.mermaid" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.directive.end.mermaid" }
      },
      "patterns": [
        { "name": "source.js.embedded.mermaid", "match": ".*" }
      ]
    },
    "diagramTypes": {
      "name": "keyword.control.diagram.mermaid",
      "match": "\\b(flowchart|graph|sequenceDiagram|gantt|pie|mindmap|timeline|gitGraph|erDiagram|classDiagram|classDiagram-v2|stateDiagram|stateDiagram-v2|journey|C4Context|C4Container|C4Component|C4Dynamic|C4Deployment|requirement|requirementDiagram|sankey|sankeyDiagram|quadrantChart|xychart|xychart-beta|zenuml|architecture|block|blockDiagram|packet|packet-beta|kanban|radar|radar-beta|info)\\b"
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-percent.mermaid",
          "match": "%%.*$"
        }
      ]
    },
    "transitions": {
      "patterns": [
        {
          "name": "keyword.control.transition.mermaid",
          "match": "(-{2,}|-{1,}>|\\.{2,}|\\.->|==+|={1,}>)"
        },
        {
          "name": "keyword.control.transition.mermaid",
          "match": "(--?>?>|--?[)x])[+-]?"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mermaid",
          "match": "\".*?\""
        },
        {
          "name": "string.quoted.curly.mermaid",
          "match": "\\{[^{}]+\\}"
        },
        {
          "name": "string.quoted.bracket.mermaid",
          "match": "\\[[^\\[\\]]+\\]"
        },
        {
          "name": "string.quoted.parenthesis.mermaid",
          "match": "\\([^()]+\\)"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.mermaid",
          "match": "\\b[A-Za-z][\\w$]*\\b"
        }
      ]
    }
  },
  "fileTypes": ["mermaid", "mmd"],
  "uuid": "b8c3e9b0-472f-4578-8ac8-1dceecb6b1a3"
}
