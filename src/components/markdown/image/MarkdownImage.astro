---
import Panzoom from '@/components/panzoom/panzoom.astro'
import { getAssetBlob } from '@/libs/structure-db';
import { log_debug } from '@/libs/utils';
import { config } from '@/config';

export interface Props {
    item: {
        slug: string;
        asset_uid: string;
        blob_uid: string;
        ast?: { options?: { height?: string; width?: string; center?: boolean } };
    };
}

const {item} = Astro.props as Props;

const alt = item.slug;
const blob_uid = getAssetBlob(item.asset_uid, config.collect.version_id);
const asseturl = `/assets/${blob_uid}:${item.asset_uid}`;
const meta = {};
// Inline image directives may carry display options (height/width/center).
const options = item.ast?.options ?? {};
log_debug(`  - MarkdownImage> asseturl: ${asseturl}`);
---
<Panzoom src={asseturl} alt={alt} title={""} meta={meta}
  height={options.height} width={options.width} center={options.center} />
