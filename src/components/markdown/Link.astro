---
import ModelViewer from './model/ModelViewer.astro';
import {getAssetInfo, getAssetUrl} from '@/libs/structure-db';
import Code from './code/Code.astro';
import {config} from '@/config';
import {resolveLinkPresentation} from './link-presentation.js';
import './Link.css';

export interface Props {
    item: {
      asset_uid?: string;
      doc_sid?: string;
      version_id?: string;
      body_text: string;
      ast: {
          title: string;
          url: string;
          rel?: {
            status?: string;
            target_sid?: string;
            raw?: string;
            fragment?: string | null;
            external?: boolean;
          };
      };
    };
}

const {item} = Astro.props as Props;
const hasAsset = item.asset_uid != null;
const versionId = item.version_id ?? config.collect.version_id;
const presentation = hasAsset ? null : resolveLinkPresentation({
  ast: item.ast,
  docSid: item.doc_sid,
  versionId
});

let url = hasAsset ? getAssetUrl(item.asset_uid!, versionId) : presentation?.href;
let is_model3d = false;
let is_table = false;
let is_diagram = false;
let is_link = true;

if (hasAsset) {
  const asset_info = getAssetInfo(item);
  const diagramAliases = config.diagram?.aliases ?? {};
  const normalizedExt = String(asset_info.ext ?? '').trim().toLowerCase();
  const trimmedExt = normalizedExt.startsWith('.') ? normalizedExt.slice(1) : normalizedExt;
  const diagramLanguage = diagramAliases[trimmedExt] ?? trimmedExt;
  is_model3d = asset_info.ext === 'glb' && config.profile !== 'lite';
  is_diagram = Boolean(config.diagram?.languages?.[diagramLanguage]);
  is_link = !is_model3d && !is_table && !is_diagram;
}
---
{is_model3d &&
  <ModelViewer src={url} title={item.body_text} />
}
{is_link && presentation?.unresolved &&
  <a class="link unresolved" title={presentation.title} aria-disabled="true">
    {item.body_text}
  </a>
}
{is_link && !presentation?.unresolved &&
  <a
    href={url ?? '#'}
    class={presentation?.className ?? 'link'}
    target={presentation?.target ?? '_self'}
    rel={presentation?.rel ?? undefined}
    title={presentation?.title ?? undefined}
  >
    {item.body_text}
  </a>
}
{is_diagram &&
  <Code item={item} />
}
