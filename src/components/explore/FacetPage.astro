---
import {basePrefix} from '@/libs/blob-files.js';
import {config} from '@/config';

export interface Props {
    title: string;
    description: string;
    variants?: string[];
    documents: Array<{url?: string; title?: string; description?: string; type?: string}>;
}

const {title, description, variants = [], documents} = Astro.props as Props;
const prefix = basePrefix(config.base);
---
<section class="explore-page">
    <header>
        <p class="eyebrow">Explore</p>
        <h1>{title}</h1>
        <p>{description}</p>
        {variants.length > 1 && <p class="variants">Grouped spellings: {variants.join(', ')}</p>}
    </header>
    <ul class="document-list">
        {documents.map((document) => (
            <li>
                <a href={`${prefix}/${document.url ?? ''}`}>{document.title || document.url || 'Home'}</a>
                {document.type && <span>{document.type}</span>}
                {document.description && <p>{document.description}</p>}
            </li>
        ))}
    </ul>
</section>
<style>
.explore-page{
    max-width:var(--prose-measure, 52rem);
    margin-inline:auto;
    padding:var(--space-5) var(--article-pad, var(--space-3));
}
.eyebrow{
    margin:0;
    color:var(--content-color-faint);
    font-size:.78rem;
    font-weight:700;
    letter-spacing:.1em;
    text-transform:uppercase;
}
h1{margin-block:var(--space-2)}
header > p:not(.eyebrow){color:var(--content-color-muted)}
.variants{font-size:.88rem}
.document-list{
    display:grid;
    gap:var(--space-3);
    padding:0;
    list-style:none;
}
.document-list li{
    padding:var(--space-3);
    border:1px solid var(--soft-border-color);
    border-radius:var(--radius-sm);
    background:var(--surface-2-bg, var(--nav-bg-color));
}
.document-list a{font-weight:650;color:var(--article-anchor-color)}
.document-list span{
    margin-left:var(--space-2);
    color:var(--content-color-faint);
    font-size:.8rem;
    text-transform:uppercase;
}
.document-list p{margin:.35rem 0 0;color:var(--content-color-muted)}
</style>
