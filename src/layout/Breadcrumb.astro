---
/*
 * Breadcrumb bar (OKF plan TP-10/DD-10): path/parent orientation above the
 * document. Always-on for all content — segments that map to a collected
 * document link to it, the rest render as plain text. Hidden in preview mode
 * (the popup shows only the article).
 */
import { getDocument } from '@/libs/structure-db';
import { basePrefix } from '@/libs/blob-files.js';
import { config } from '@/config';
import { extensionPreviewEnabled } from '@/libs/extension-preview.js';

export interface Props {
    data: { url?: string };
}

const { data } = Astro.props as Props;
const url = typeof data?.url === 'string' ? data.url : '';
const prefix = basePrefix(config.base);
const segments = url === '' ? [] : url.split('/');
const showPreviewHistory = extensionPreviewEnabled();

const crumbs = [];
let accumulated = '';
for (let index = 0; index < segments.length; index++) {
    accumulated = accumulated ? `${accumulated}/${segments[index]}` : segments[index];
    const isCurrent = index === segments.length - 1;
    let doc = null;
    if (!isCurrent) {
        try {
            doc = getDocument({url: accumulated});
        } catch {
            doc = null;
        }
    }
    crumbs.push({
        label: doc?.title ?? segments[index],
        href: doc ? `${prefix}/${accumulated}` : null,
        current: isCurrent,
        fallback: segments[index]
    });
}
---
{(segments.length > 0 || showPreviewHistory) &&
    <nav class="breadcrumb" aria-label="Breadcrumb">
        <div class="breadcrumb-trail">
            {segments.length > 0
                ? <a href={`${prefix}/`}>Home</a>
                : <span class="current" aria-current="page">Home</span>}
            {crumbs.map((crumb) => (
                <>
                    <span class="separator" aria-hidden="true">/</span>
                    {crumb.current
                        ? <span class="current" aria-current="page">{crumb.fallback}</span>
                        : crumb.href
                            ? <a href={crumb.href}>{crumb.label}</a>
                            : <span class="plain">{crumb.label}</span>}
                </>
            ))}
        </div>
        {showPreviewHistory &&
            <div class="preview-history-controls" role="group"
                aria-label="Rendered page history" data-preview-history-controls>
                <button type="button" data-preview-history="back" disabled
                    title="Previous rendered page" aria-label="Previous rendered page">
                    <svg viewBox="0 0 20 20" width="20" height="20" aria-hidden="true">
                        <path d="M10.5 3.5 4 10l6.5 6.5M4.5 10H17"></path>
                    </svg>
                </button>
                <button type="button" data-preview-history="forward" disabled
                    title="Next rendered page" aria-label="Next rendered page">
                    <svg viewBox="0 0 20 20" width="20" height="20" aria-hidden="true">
                        <path d="m9.5 3.5 6.5 6.5-6.5 6.5M15.5 10H3"></path>
                    </svg>
                </button>
            </div>
        }
    </nav>
}
<style>
/* Chrome band: sits on the sidebar surface (like the metadata band and the
   side rails) so the whole row under the app bar reads as one shell layer;
   the line separating it from the app bar is the header's own border in
   Layout.astro. Closed by a separator line toward the next band / body. */
.breadcrumb{
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.85em;
    color: var(--menu-text-color);
    background-color: var(--nav-bg-color);
    padding: var(--space-2) var(--article-pad);
    border-bottom: 1px solid var(--soft-border-color);
    margin: 0;
    user-select: none;
}
.breadcrumb-trail{
    display:flex;
    flex-wrap:wrap;
    align-items:center;
    gap:var(--space-1);
    min-width:0;
}
.breadcrumb-trail a{
    color: var(--menu-text-color);
    text-decoration: none;
}
.breadcrumb-trail a:hover{
    color: var(--article-anchor-color);
    text-decoration: underline;
}
.preview-history-controls{
    display:flex;
    flex:0 0 auto;
    gap:var(--space-1);
    margin-left:auto;
}
.preview-history-controls[hidden]{
    display:none;
}
.preview-history-controls button{
    display:grid;
    place-items:center;
    width:2rem;
    height:2rem;
    border:0;
    border-radius:var(--radius-sm);
    padding:0;
    color:var(--content-color);
    background:transparent;
    font:inherit;
    cursor:pointer;
}
.preview-history-controls svg{
    display:block;
    overflow:visible;
}
.preview-history-controls path{
    fill:none;
    stroke:currentColor;
    stroke-width:1.45;
    stroke-linecap:round;
    stroke-linejoin:round;
}
.preview-history-controls button:hover:not(:disabled){
    color:var(--content-color);
    background:var(--header-active-color);
}
.preview-history-controls button:focus-visible{
    outline:2px solid var(--front-blue);
    outline-offset:1px;
}
.preview-history-controls button:disabled{
    opacity:0.42;
    cursor:default;
}
.separator{
    opacity: 0.6;
}
.current{
    color: var(--content-color);
}
:global(html[data-preview-mode="true"]) .breadcrumb{
    display: none;
}
</style>
