---
import './colors.css';
import SubMenu from "./SubMenu.astro";
import {createHash} from 'node:crypto';
import {config} from '../../config.js';

export interface Props {
  items: Array<Object>;
  contentsItems?: Array<Object>;
  category: string;
  initialOpen?: boolean;
  loading?: boolean;
}

let { items, contentsItems = [], category, initialOpen = true, loading = false } = Astro.props;

const open_class = ((items.length > 0 || contentsItems.length > 0) && initialOpen)?"open":"closed"
const data_width = (items.length > 0 || contentsItems.length > 0 || loading)?"20vw":"0vw"

function getMaxDepth(entries, level = 1) {
  let max = level;
  for (const entry of entries ?? []) {
    if (Array.isArray(entry.items) && entry.items.length > 0) {
      max = Math.max(max, getMaxDepth(entry.items, level + 1));
    }
  }
  return max;
}

function collectActiveLinks(entry, accumulator = []) {
  let isActiveBranch = Boolean(entry.active);
  for (const child of entry.items ?? []) {
    if (collectActiveLinks(child, accumulator)) {
      isActiveBranch = true;
    }
  }
  if (isActiveBranch && entry.link) {
    accumulator.push(entry.link);
  }
  return isActiveBranch;
}

const files_max_level = getMaxDepth(items);
const contents_max_level = getMaxDepth(contentsItems);
const max_level = Math.max(files_max_level, contents_max_level);
const has_contents = category !== "toc_menu" && contentsItems.length > 0;
const default_level = 1;
const link_class = category === "toc_menu" ? "toc_href" : "";
const auto_title = category === "toc_menu" ? "Auto - follow scroll" : "Auto - fit height";
const initial_mode = category === "toc_menu" ? "auto" : "manual";
const initial_depth = default_level;
const show_initial_depth = category !== "toc_menu" || initial_mode === "manual";
const initial_title = initial_mode === "auto"
  ? auto_title
  : `Manual - click for ${auto_title.toLowerCase()}`;
const activePathEntries = [];
for (const entry of items) {
  collectActiveLinks(entry, activePathEntries);
}
for (const entry of contentsItems) {
  collectActiveLinks(entry, activePathEntries);
}
const activePath = new Set(activePathEntries);
const state_scope = createHash('sha1')
  .update(`${config.workspaceRoot}|${config.content_path}`)
  .digest('hex')
  .slice(0, 12);
const state_key = `microwebstacks:${state_scope}:${category}`;
---
<nav class={`${open_class} ${category}${loading ? " loading" : ""}`} data-width={data_width} data-max-level={max_level} data-default-level={default_level} data-state-key={state_key} data-lazy-navigation={loading ? "true" : undefined} aria-busy={loading ? "true" : undefined}>
    <div class="menu-title">
      {category === "toc_menu" ? "On this page" : has_contents ?
        <div class="menu-source-toggle" role="group" aria-label="Navigation source">
          <button type="button" data-menu-source="contents" aria-pressed="true">Contents</button>
          <button type="button" data-menu-source="files" aria-pressed="false">Files</button>
        </div>
        : "Pages"}
    </div>
    {loading &&
      <div class="menu-skeleton" aria-label="Loading pages" role="status">
        <span></span><span></span><span></span><span></span><span></span>
      </div>
    }
    {(items.length > 0 && max_level > 1) &&
      <div class="depth-controls" data-category={category} role="group" aria-label="Tree depth">
        <button type="button" class="depth-btn" data-action="min" title="Show top level" aria-label="Show top level">1</button>
        <button type="button" class="depth-btn" data-action="down" title="Show one less level" aria-label="Show one less level">&minus;</button>
        <button type="button" class={`depth-btn auto${initial_mode === "manual" ? " manual" : ""}`} data-action="auto" data-mode={initial_mode} title={initial_title} aria-label={initial_title}>
          <span data-mode-label>{initial_mode === "auto" ? "Auto" : "Manual"}</span>
          <span class={`mode-level${show_initial_depth ? "" : " is-hidden"}`} aria-hidden={show_initial_depth ? "false" : "true"} data-depth-label>{initial_depth}</span>
        </button>
        <button type="button" class="depth-btn" data-action="up" title="Show one more level" aria-label="Show one more level">+</button>
        <button type="button" class="depth-btn all" data-action="max" title="Show all levels" aria-label="Show all levels">All</button>
      </div>
    }
    {has_contents &&
      <div class="menu-tree" data-menu-tree="contents" data-max-depth={contents_max_level}>
        <SubMenu items={contentsItems} level={1} visibleLevel={default_level} activePath={activePath} forceVisible={false} linkClass={link_class} />
      </div>
    }
    <div class="menu-tree" data-menu-tree="files" data-max-depth={files_max_level} hidden={has_contents}>
      <SubMenu items={items} level={1} visibleLevel={default_level} activePath={activePath} forceVisible={false} linkClass={link_class} />
    </div>
</nav>

<style define:vars={{ data_width }}>
nav{
    background: var(--nav-bg-color);
    width:var(--data_width);
    height:100%;
    overflow-y: auto;
    flex-shrink: 0;
}
.menu-title{
  position:sticky;
  top:0;
  z-index:2;
  min-height:2.5rem;
  display:flex;
  align-items:center;
  padding-inline:var(--space-3);
  font-size:var(--text-sm);
  font-weight:600;
  color:var(--content-color-muted);
  background:var(--nav-bg-color);
  border-bottom:1px solid var(--soft-border-color);
}
.menu-source-toggle{
  display:grid;
  grid-template-columns:1fr 1fr;
  width:100%;
  gap:2px;
  padding:2px;
  border:1px solid var(--soft-border-color);
  border-radius:var(--radius-sm);
}
.menu-source-toggle button{
  border:0;
  border-radius:calc(var(--radius-sm) - 2px);
  padding:var(--space-1) var(--space-2);
  background:transparent;
  color:var(--content-color-muted);
  cursor:pointer;
}
.menu-source-toggle button[aria-pressed="true"]{
  background:var(--menu-active-color);
  color:var(--content-color);
}
.menu-tree[hidden]{display:none}
nav.closed{
    width:0px;
}
nav.open{
    width:var(--data_width);
}
.menu-skeleton{
  display:flex;
  flex-direction:column;
  gap:var(--space-3);
  padding:var(--space-4) var(--space-3);
}
.menu-skeleton span{
  display:block;
  width:78%;
  height:0.8rem;
  border-radius:var(--radius-sm);
  background:color-mix(in srgb, var(--content-color-muted) 22%, transparent);
  animation:menu-skeleton-pulse 1.2s ease-in-out infinite alternate;
}
.menu-skeleton span:nth-child(2),
.menu-skeleton span:nth-child(5){ width:58%; }
.menu-skeleton span:nth-child(3){ width:88%; }
@keyframes menu-skeleton-pulse{
  from{ opacity:0.45; }
  to{ opacity:0.9; }
}
@media (prefers-reduced-motion: reduce){
  .menu-skeleton span{ animation:none; }
}
nav::-webkit-scrollbar {
  width: 1rem;
}
nav::-webkit-scrollbar-track {
  background: var(--nav-bg-color); 
}
nav::-webkit-scrollbar-thumb {
  background: var(--scroll-thumb-color); 
}
nav::-webkit-scrollbar-thumb:hover {
  background: var(--scroll-thumb-hover-color);
}
nav::-webkit-scrollbar-corner {
  background: var(--nav-bg-color);
}

@media only screen and (max-width: 700px) {
  nav{
      width:100%;
  }
}

/* Control strip: a distinct chrome band so it reads as a toolbar, with the
   page tree / outline clearly beginning below the divider. Sticks to the top
   while the menu scrolls. */
.depth-controls{
  position: sticky;
  top: 2.5rem;
  z-index: 1;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-direction: row;
  gap:0.15rem;
  padding:var(--space-1) 0.15rem;
  color:var(--content-color);
  background: var(--nav-bg-color);
  border-top: 1px solid var(--soft-border-color);
  border-bottom: 1px solid var(--soft-border-color);
  box-shadow: inset 0 1px 0 color-mix(in srgb, var(--header-bg-color) 35%, transparent);
}
nav.toc_menu .depth-controls{
  justify-content:center;
}
.depth-btn{
  width: 2rem;
  height: 2rem;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  background: transparent;
  border: 1px solid transparent;
  border-radius: var(--radius-sm);
  color: var(--content-color);
  padding: 2px;
  font-size: var(--text-sm);
  line-height: 1;
  cursor: pointer;
  user-select: none;
}
.depth-btn.all{
  width:auto;
  min-width:2.25rem;
  padding-inline:var(--space-1);
}
.depth-btn:focus-visible{
  outline: 2px solid var(--front-blue);
  outline-offset: -2px;
}
.depth-btn.auto{
  width: auto;
  min-width: 2.75rem;
  gap: var(--space-1);
  padding-inline: var(--space-1);
}
.depth-btn:hover{
  background: var(--menu-span-hover-color);
}
.depth-btn.active{
  background: var(--menu-active-color);
  border-color: var(--front-blue);
  color: var(--content-color);
}
.depth-btn.auto.manual{
  color: var(--content-color-muted);
}
.mode-level{
  min-width: 0.65rem;
  font-size: var(--text-sm);
  font-variant-numeric: tabular-nums;
  line-height: 1;
  color: var(--content-color-muted);
}
.mode-level.is-hidden{
  display: none;
}
.depth-btn.active .mode-level,
.depth-btn.auto.manual .mode-level{
  color: var(--content-color);
}
nav.measuring ul.nested{
  transition-duration: 0s;
}

</style>

<script src="./menu_source_toggle.js" />
