---
import './colors.css';
import './tokens.css';
import 'katex/dist/katex.min.css';
import AppBar from './AppBar.astro';
import SideMenu from './SideMenu.astro';
import { process_toc_list, buildNavigationMenus } from "./layout_utils";


export interface Props {
	title: string;
	headings: Array<Object>;
}

const { headings } = Astro.props;
const rawTitle = ((Astro.props as any).frontmatter || Astro.props).title;
// The root content doc carries "." as its title; show "Home" instead
// (mirrors homeLabel() used for the nav).
const title = (!rawTitle || rawTitle === '.') ? 'Home' : rawTitle;
const toc_menu_items = process_toc_list(headings)
const navigation = buildNavigationMenus(Astro.url.pathname)
const pages_menu_items = navigation.sectionMenu ?? []
const appbar_menu = navigation.appBarMenu ?? []
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		{/* Before any CSS arrives the browser paints its default canvas; this
		    meta makes that canvas follow the OS scheme (dark instead of white
		    for dark-mode users). The inline script below narrows it to the
		    resolved theme once the stored preference is known. */}
		<meta name="color-scheme" content="dark light" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`}>
		<script is:inline>
			// Resolve and apply the theme before first paint to avoid a
			// flash of the wrong palette (bright flash on dark, dark flash on light).
			(function () {
				try {
					var pref = localStorage.getItem('theme-pref') || 'auto';
					if (pref !== 'light' && pref !== 'dark' && pref !== 'auto') {
						pref = 'auto';
					}
					var resolved = pref;
					if (pref === 'auto') {
						resolved = window.matchMedia('(prefers-color-scheme: light)').matches
							? 'light'
							: 'dark';
					}
					var root = document.documentElement;
					root.setAttribute('data-theme', resolved);
					root.setAttribute('data-theme-pref', pref);
					// Narrow the color-scheme meta to the resolved theme so the
					// pre-paint canvas matches even when the stored preference
					// disagrees with the OS scheme.
					var meta = document.querySelector('meta[name="color-scheme"]');
					if (meta) meta.setAttribute('content', resolved);
				} catch (e) {
					document.documentElement.setAttribute('data-theme', 'dark');
					document.documentElement.setAttribute('data-theme-pref', 'auto');
				}
			})();
		</script>
		<style is:inline>
			/* Critical pre-stylesheet paint: give the page its real background
			   the instant anything paints, instead of a white flash while the
			   bundled CSS downloads. Hex values mirror --content-bg-color in
			   colors.css (keep in sync). Default is dark, matching the site's
			   no-JS fallback. */
			html { background-color: #1E1E1E; }
			html[data-theme="light"] { background-color: #FFFFFF; }

			/* Boot spinner: visible only while <body> has no parsed content yet
			   (the SSR streaming gap on large pages); disappears as soon as the
			   first body element arrives. Neutral grey works on both themes.
			   Browsers without :has() drop the rule — they just keep the plain
			   background. */
			html:not(:has(body > *))::after {
				content: "";
				position: fixed;
				inset: 0;
				margin: auto;
				width: 28px;
				height: 28px;
				border-radius: 50%;
				border: 3px solid rgba(128, 128, 128, 0.3);
				border-top-color: rgba(128, 128, 128, 0.85);
				animation: boot-spin 0.8s linear infinite;
			}
			@keyframes boot-spin {
				to { transform: rotate(360deg); }
			}
			@media (prefers-reduced-motion: reduce) {
				html:not(:has(body > *))::after { animation: none; }
			}
		</style>
	</head>
	<body >
		<div class="appbar-nav_content-footer">
			<header>
				<AppBar menu={appbar_menu} showLeftToggle={pages_menu_items.length > 0} showRightToggle={toc_menu_items.visible} />
			</header>
			<main>
				<div id="wide-nav" class="scroll">
					<SideMenu items={pages_menu_items} category="pages_menu" initialOpen={false}/>
				</div>
				<div id="resize-left" class="nav-resize active"/>
				<article class="content scroll">
					<div id="mobile-nav">
						<SideMenu items={pages_menu_items} category="pages_menu" initialOpen={false}/>
					</div>
					<div class="article-slot">
						<slot/>
					</div>
				</article>
				<div id="resize-right" class="nav-resize active"/>
				<div id="toc-nav-div">
					{toc_menu_items.visible && 
						<SideMenu items={toc_menu_items.items} category="toc_menu" initialOpen={false}/>
					}
				</div>
			</main>
			<button id="mobile-nav-backdrop" type="button" aria-label="Close navigation menus"></button>
		</div>
	</body>
</html>


<style>
body{
	margin:0;
	font-family: var(--font-sans);
	font-size: var(--text-base);
	line-height: var(--leading-body);
	display:flex;
	flex-direction: row;
	background-color: var(--content-bg-color);
	color: var(--content-color);
}
body.mobile-nav-open{
	overflow:hidden;
}
/* Body => .appbar-nav_content-footer (full width; the app bar owns nav toggles) */
.appbar-nav_content-footer{
	flex-grow:1;
	display:flex;
	flex-direction: column;
	height:100vh;
}
/* appbar-nav_content-footer => header, main */
header{
    flex-grow:0;
	background-color: var(--header-bg-color);
    width:100%;
    user-select: none;
}
main{
	flex-grow:1;
	display:flex;
	flex-direction: row;
	height:80vh;
	max-width: 100vw;
	min-width: 0;
}
/* main => #wide-nav, resize-left, article.content, #resize-right, #toc-nav-div */

#wide-nav{
	background: var(--nav-bg-color);
}
#mobile-nav{
	display: none;
}
.content{
	color:var(--content-color);
	background-color: var(--content-bg-color);
	width:100%;
	flex-grow: 0;
	overflow:auto;
	padding:var(--space-3);
	box-sizing:border-box;
	min-width:0;
    scroll-behavior: smooth;
    scroll-padding-top: var(--space-3);
}
#toc-nav-div{
	background: var(--nav-bg-color);
	flex-grow: 0;
	flex-shrink: 0;
}


.nav-resize{
	width:var(--space-2);
	background-color: var(--content-bg-color);
	border-inline:1px solid transparent;
	box-sizing:border-box;
}
.active.nav-resize{
	cursor:col-resize;
}
.active.nav-resize:hover{
	background-color: var(--front-blue);
	transition: background-color 0.5s;
}
#mobile-nav-backdrop{
	display:none;
}
.scroll::-webkit-scrollbar {
	width: 1rem;
}
.scroll::-webkit-scrollbar-track {
	background: var(--content-bg-color); 
}
.scroll::-webkit-scrollbar-thumb {
	background: var(--scroll-thumb-color); 
}
.scroll::-webkit-scrollbar-thumb:hover {
  background: var(--scroll-thumb-hover-color); 
}
.scroll::-webkit-scrollbar-corner {
	background: var(--content-bg-color);
}

@media only screen and (max-width: 700px) {
	#resize-right, #resize-left {
		display:none;
	}
	.content{
		padding:var(--space-4);
	}
	#wide-nav{
		display:none;
	}
	#mobile-nav,
	#toc-nav-div{
		display:block;
		position:fixed;
		top:54px;
		bottom:0;
		z-index:20;
		width:min(84vw, 20rem);
		background:var(--nav-bg-color);
		box-shadow:var(--shadow-raised);
		transition:transform 0.2s ease;
		pointer-events:none;
	}
	#mobile-nav{
		left:0;
		transform:translateX(-102%);
	}
	#toc-nav-div{
		right:0;
		transform:translateX(102%);
	}
	#mobile-nav.mobile-open,
	#toc-nav-div.mobile-open{
		transform:translateX(0);
		pointer-events:auto;
	}
	#mobile-nav :global(nav),
	#toc-nav-div :global(nav){
		width:100% !important;
		height:100%;
	}
	#mobile-nav-backdrop{
		position:fixed;
		inset:54px 0 0;
		z-index:19;
		width:100%;
		height:auto;
		border:0;
		padding:0;
		background:rgba(0,0,0,0.42);
		cursor:pointer;
	}
	#mobile-nav-backdrop.visible{
		display:block;
	}
}

/* --- Article reading surface -------------------------------------------
   Typography for rendered markdown. Mirrors GitHub's markdown rhythm
   (16px / 1.6 line-height, 1rem block spacing, stepped headings) so the
   reading experience matches a familiar, well-tuned reference. Tokens
   from tokens.css; no literal sizes here. */

.article-slot{
	font-size: var(--text-base);
	line-height: var(--leading-body);
}

.article-slot :global(a){
	color:var(--article-anchor-color);
}

/* Body paragraphs: capped measure for legibility, even block spacing.
   Standalone paragraphs render as <p>; text that flows around inline links
   stays as loose nodes and inherits the article line-height. */
.article-slot :global(p){
	max-width: var(--prose-measure);
	margin-block: 0 var(--space-4);
	line-height: var(--leading-body);
}

/* Headings: stepped scale, tighter leading, generous space above. */
.article-slot :global(.heading){
	line-height: var(--leading-heading);
	font-weight: 600;
	margin-block: var(--space-5) var(--space-4);
}
.article-slot :global(h1.heading){ font-size: var(--text-h1); }
.article-slot :global(h2.heading){ font-size: var(--text-h2); }
.article-slot :global(h3.heading){ font-size: var(--text-h3); }
.article-slot :global(h4.heading),
.article-slot :global(h5.heading),
.article-slot :global(h6.heading){ font-size: var(--text-h4); }

/* Lists: indent + the same block rhythm as paragraphs. */
.article-slot :global(ul),
.article-slot :global(ol){
	max-width: var(--prose-measure);
	margin-block: 0 var(--space-4);
	padding-left: var(--space-6);
	line-height: var(--leading-body);
}
.article-slot :global(li + li){
	margin-top: var(--space-1);
}

/* Inline code: subtle tinted chip, like GitHub. */
.article-slot :global(:not(pre) > code){
	padding: 0.15em 0.4em;
	font-size: 0.9em;
	background-color: var(--surface-2-bg);
	border-radius: var(--radius-sm);
}

/* Blockquotes: muted text behind an accent rule. */
.article-slot :global(blockquote){
	max-width: var(--prose-measure);
	margin-block: 0 var(--space-4);
	padding: 0 var(--space-4);
	color: var(--content-color-muted);
	border-left: 0.25em solid var(--soft-border-color);
}

.article-slot :global(.katex-display){
	max-width: 100%;
	overflow-x: auto;
	overflow-y: hidden;
	margin-block: var(--space-4);
	padding-bottom: 0.15rem;
}

</style>

<script src="./menu_interactions_activation.js" />
