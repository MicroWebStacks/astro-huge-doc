---
import './colors.css';
import './tokens.css';
import 'katex/dist/katex.min.css';
import AppBar from './AppBar.astro';
import SideMenu from './SideMenu.astro';
import LinkPreviewOverlay from '@/components/linkpreview/LinkPreviewOverlay.astro';
import LiteRelationIndexer from './LiteRelationIndexer.astro';
import { process_toc_list, buildAppBarMenu, buildNavigationMenusWithContents, findKnowledgeLog } from "./layout_utils";
import { extensionPreviewEnabled } from '@/libs/extension-preview.js';
import { config } from '@/config';


export interface Props {
	title: string;
	headings: Array<Object>;
}

const { headings } = Astro.props;
const rawTitle = ((Astro.props as any).frontmatter || Astro.props).title;
// The root content doc carries "." as its title; show "Home" instead
// (mirrors homeLabel() used for the nav).
const title = (!rawTitle || rawTitle === '.') ? 'Home' : rawTitle;
const toc_menu_items = process_toc_list(headings)
// Single gate shared with the /__lite/* endpoints (src/middleware.js): the UI
// this flag emits and the endpoints it relies on must switch together, in
// every run mode. Never read the env var directly here — see
// specification/run-modes/spec.md.
const liveReload = extensionPreviewEnabled()
// In extension mode the article is the critical response. Its pages rail is
// fetched after first paint and starts as a closed skeleton; static/full
// deployments keep their complete server-rendered navigation.
const navigation = liveReload
	? {appBarMenu: buildAppBarMenu(Astro.url.pathname), sectionMenu: [], contentsMenu: []}
	: await buildNavigationMenusWithContents(Astro.url.pathname)
const pages_menu_items = navigation.sectionMenu ?? []
const contents_menu_items = navigation.contentsMenu ?? []
const appbar_menu = navigation.appBarMenu ?? []
// Reserved log.md (OKF plan DD-8): the app bar links to the knowledge log
// only when the validation gate passes; otherwise it is a normal page.
const logPage = findKnowledgeLog()
// Extension preview only: pages poll the local server's /__lite/version and
// reload themselves in place when the extension bumps a change stamp. Keeps
// the current URL across edits (the server never restarts). Purely local —
// nothing is collected or sent anywhere.
// The poller is emitted only when a launcher identity is present: stamps are
// bumped exclusively by launchers (the VS Code extension), so in a manual
// `pnpm dev`/`pnpm server` run the 1 s poll could never observe a change and
// would only flood the request log (specification/run-modes/spec.md).
const liveReloadPolling = liveReload && Boolean(process.env.MICROWEBSTACKS_LAUNCHER)
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		{/* Before any CSS arrives the browser paints its default canvas; this
		    meta makes that canvas follow the OS scheme (dark instead of white
		    for dark-mode users). The inline script below narrows it to the
		    resolved theme once the stored preference is known. */}
		<meta name="color-scheme" content="dark light" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`}>
		<script is:inline>
			// Resolve and apply the theme before first paint to avoid a
			// flash of the wrong palette (bright flash on dark, dark flash on light).
			(function () {
				try {
					var pref = localStorage.getItem('theme-pref') || 'auto';
					if (pref !== 'light' && pref !== 'dark' && pref !== 'auto') {
						pref = 'auto';
					}
					var resolved = pref;
					if (pref === 'auto') {
						resolved = window.matchMedia('(prefers-color-scheme: light)').matches
							? 'light'
							: 'dark';
					}
					var root = document.documentElement;
					root.setAttribute('data-theme', resolved);
					root.setAttribute('data-theme-pref', pref);
					// Narrow the color-scheme meta to the resolved theme so the
					// pre-paint canvas matches even when the stored preference
					// disagrees with the OS scheme.
					var meta = document.querySelector('meta[name="color-scheme"]');
					if (meta) meta.setAttribute('content', resolved);
				} catch (e) {
					document.documentElement.setAttribute('data-theme', 'dark');
					document.documentElement.setAttribute('data-theme-pref', 'auto');
				}
			})();
		</script>
		<script is:inline>
			// Preview-mode detection (page-render-preview plan, AD-002/AD-005). A
			// previewed page loads inside an iframe at "<url>#__preview" (optionally
			// "#__preview&<section>" for the OP-002/OP-008 section-scroll
			// best-effort). Runs before <body> so the chrome-hiding CSS below has
			// zero flash, and exposes data-preview-mode on <html> so both that CSS
			// and link_preview.js read the one flag instead of re-deriving it.
			(function () {
				try {
					var hash = window.location.hash || '';
					var flag = '#__preview';
					var isPreview = hash === flag || hash.indexOf(flag + '&') === 0;
					// Belt-and-braces (OP-002): if the fragment was lost (e.g. some
					// navigation normalizes it away) but this document sits in a
					// same-origin iframe placed by link_preview.js, its dataset still
					// carries the flag.
					if (!isPreview) {
						try {
							isPreview = Boolean(window.frameElement && window.frameElement.dataset.mwsPreview === 'true');
						} catch (e) {
							// cross-origin frameElement access - not applicable here, ignore
						}
					}
					var root = document.documentElement;
					root.setAttribute('data-preview-mode', isPreview ? 'true' : 'false');
					var ampIndex = hash.indexOf('&');
					if (isPreview && ampIndex !== -1) {
						root.setAttribute('data-preview-section', decodeURIComponent(hash.slice(ampIndex + 1)));
					}
				} catch (e) {
					document.documentElement.setAttribute('data-preview-mode', 'false');
				}
			})();
		</script>
		<style is:inline>
			/* Critical pre-stylesheet paint: give the page its real background
			   the instant anything paints, instead of a white flash while the
			   bundled CSS downloads. Hex values mirror --content-bg-color in
			   colors.css (keep in sync). Default is dark, matching the site's
			   no-JS fallback. */
			html { background-color: #1E1E1E; }
			html[data-theme="light"] { background-color: #FFFFFF; }

			/* Boot spinner: visible only while <body> has no parsed content yet
			   (the SSR streaming gap on large pages); disappears as soon as the
			   first body element arrives. Neutral grey works on both themes.
			   Browsers without :has() drop the rule — they just keep the plain
			   background. */
			html:not(:has(body > *))::after {
				content: "";
				position: fixed;
				inset: 0;
				margin: auto;
				width: 28px;
				height: 28px;
				border-radius: 50%;
				border: 3px solid rgba(128, 128, 128, 0.3);
				border-top-color: rgba(128, 128, 128, 0.85);
				animation: boot-spin 0.8s linear infinite;
			}
			@keyframes boot-spin {
				to { transform: rotate(360deg); }
			}
			@media (prefers-reduced-motion: reduce) {
				html:not(:has(body > *))::after { animation: none; }
			}
		</style>
	</head>
	<body >
		<div class="appbar-nav_content-footer">
			<header>
				<AppBar menu={appbar_menu} showLeftToggle={liveReload || pages_menu_items.length > 0} showRightToggle={toc_menu_items.visible} showRuntimeInfo={liveReload} exploreEnabled={config.profile !== 'lite'} logPage={logPage} />
			</header>
			<main>
				<div id="wide-nav" class="scroll">
					<SideMenu items={pages_menu_items} contentsItems={contents_menu_items} category="pages_menu" initialOpen={false} loading={liveReload}/>
				</div>
				<div id="resize-left" class="nav-resize active"/>
				<article class="content scroll">
					<div id="mobile-nav">
						<SideMenu items={pages_menu_items} contentsItems={contents_menu_items} category="pages_menu" initialOpen={false} loading={liveReload}/>
					</div>
					<div class="article-slot">
						<slot/>
					</div>
				</article>
				<div id="resize-right" class="nav-resize active"/>
				<div id="toc-nav-div">
					{toc_menu_items.visible && 
						<SideMenu items={toc_menu_items.items} category="toc_menu" initialOpen={false}/>
					}
				</div>
			</main>
			<button id="mobile-nav-backdrop" type="button" aria-label="Close navigation menus"></button>
		</div>
		<LinkPreviewOverlay />
		{liveReload && <LiteRelationIndexer />}
		{liveReloadPolling &&
			<script is:inline>
				// Extension live reload: poll the local preview server's change
				// stamps; reload in place when they move. Local only.
				(function () {
					let baseline = null;
					async function poll() {
						try {
							const response = await fetch('/__lite/version', {cache: 'no-store'});
							if (!response.ok) return;
							const version = await response.json();
							const stamp = `${version.reload}:${version.tree}`;
							if (baseline === null) {
								baseline = stamp;
							} else if (stamp !== baseline) {
								window.location.reload();
							}
						} catch (_error) {
							// server briefly unavailable; keep polling
						}
					}
					setInterval(poll, 1000);
					poll();
				})();
			</script>
		}
	</body>
</html>


<style>
body{
	margin:0;
	font-family: var(--font-sans);
	font-size: var(--text-base);
	line-height: var(--leading-body);
	display:flex;
	flex-direction: row;
	background-color: var(--content-bg-color);
	color: var(--content-color);
}
body.mobile-nav-open{
	overflow:hidden;
}
/* Body => .appbar-nav_content-footer (full width; the app bar owns nav toggles) */
.appbar-nav_content-footer{
	flex-grow:1;
	display:flex;
	flex-direction: column;
	height:100vh;
}
/* appbar-nav_content-footer => header, main */
header{
    flex-grow:0;
	background-color: var(--header-bg-color);
	/* Full-width line closing the app bar: marks where the bar ends against
	   the nav-colored shell row below it (sidebars + breadcrumb band). */
	border-bottom: 1px solid var(--soft-border-color);
	box-sizing: border-box;
    width:100%;
    user-select: none;
}
main{
	flex-grow:1;
	display:flex;
	flex-direction: row;
	height:80vh;
	max-width: 100vw;
	min-width: 0;
}
/* main => #wide-nav, resize-left, article.content, #resize-right, #toc-nav-div */

#wide-nav{
	background: var(--nav-bg-color);
}
#mobile-nav{
	display: none;
}
.content{
	/* --article-pad: single source for the article gutter, so chrome bands
	   (breadcrumb, frontmatter, relations footer) can bleed edge-to-edge with
	   negative margins that stay in sync across breakpoints. */
	--article-pad: var(--space-3);
	display:flex;
	flex-direction:column;
	color:var(--content-color);
	background-color: var(--content-bg-color);
	width:100%;
	flex-grow: 0;
	overflow:auto;
	padding:var(--article-pad);
	box-sizing:border-box;
	min-width:0;
    scroll-behavior: smooth;
    scroll-padding-top: var(--space-3);
}
#toc-nav-div{
	background: var(--nav-bg-color);
	flex-grow: 0;
	flex-shrink: 0;
}


.nav-resize{
	/* Keep the navigation boundary visible without reserving a white gutter.
	   The pseudo-element below retains a comfortably sized resize target. */
	position:relative;
	width:1px;
	background-color: var(--soft-border-color);
	box-sizing:border-box;
}
.nav-resize::after{
	content:"";
	position:absolute;
	inset:0 calc(-1 * var(--space-2));
}
.active.nav-resize{
	cursor:col-resize;
}
.active.nav-resize:hover{
	background-color: var(--front-blue);
	transition: background-color 0.5s;
}
#mobile-nav-backdrop{
	display:none;
}
.scroll::-webkit-scrollbar {
	width: 1rem;
}
.scroll::-webkit-scrollbar-track {
	background: var(--content-bg-color); 
}
.scroll::-webkit-scrollbar-thumb {
	background: var(--scroll-thumb-color); 
}
.scroll::-webkit-scrollbar-thumb:hover {
  background: var(--scroll-thumb-hover-color); 
}
.scroll::-webkit-scrollbar-corner {
	background: var(--content-bg-color);
}

@media only screen and (max-width: 700px) {
	#resize-right, #resize-left {
		display:none;
	}
	.content{
		--article-pad: var(--space-4);
	}
	#wide-nav{
		display:none;
	}
	#mobile-nav,
	#toc-nav-div{
		display:block;
		position:fixed;
		top:54px;
		bottom:0;
		z-index:20;
		width:min(84vw, 20rem);
		background:var(--nav-bg-color);
		box-shadow:var(--shadow-raised);
		transition:transform 0.2s ease;
		pointer-events:none;
	}
	#mobile-nav{
		left:0;
		transform:translateX(-102%);
	}
	#toc-nav-div{
		right:0;
		transform:translateX(102%);
	}
	#mobile-nav.mobile-open,
	#toc-nav-div.mobile-open{
		transform:translateX(0);
		pointer-events:auto;
	}
	#mobile-nav :global(nav),
	#toc-nav-div :global(nav){
		width:100% !important;
		height:100%;
	}
	#mobile-nav-backdrop{
		position:fixed;
		inset:54px 0 0;
		z-index:19;
		width:100%;
		height:auto;
		border:0;
		padding:0;
		background:rgba(0,0,0,0.42);
		cursor:pointer;
	}
	#mobile-nav-backdrop.visible{
		display:block;
	}
}

/* --- Article reading surface -------------------------------------------
   Typography for rendered markdown. Mirrors GitHub's markdown rhythm
   (16px / 1.6 line-height, 1rem block spacing, stepped headings) so the
   reading experience matches a familiar, well-tuned reference. Tokens
   from tokens.css; no literal sizes here. */

/* Column layout so short pages still pin the relations footer to the bottom
   of the scroll area instead of leaving a dead band above the viewport edge.
   Slot children are wrapper blocks (page-chrome / markdown wrapper / footer),
   so losing margin collapsing between them changes nothing visible. */
.article-slot{
	flex: 1 0 auto;
	display: flex;
	flex-direction: column;
	font-size: var(--text-base);
	line-height: var(--leading-body);
}
.article-slot > :global(*){
	flex: 0 0 auto;
}
.article-slot :global(.relations-footer){
	/* A flex auto margin collapses to zero on long articles, letting the
	   footer border run directly into the last markdown block. */
	margin-top: var(--space-7);
}

/* --- Page chrome bands ---------------------------------------------------
   Everything not authored in markdown (breadcrumb, frontmatter viewer,
   relations footer) sits on shell surfaces, not the reading surface: the
   breadcrumb continues the app bar, the metadata/relations bands continue
   the sidebars, each closed by a 1px separator line before the body. The
   wrapper cancels the article gutter so the bands run edge-to-edge. */
.article-slot :global(.page-chrome){
	margin: calc(-1 * var(--article-pad)) calc(-1 * var(--article-pad)) var(--space-5);
}
.article-slot :global(.page-chrome:not(:has(*))){
	display: none;
}
:global(html[data-preview-mode="true"]) .article-slot :global(.page-chrome){
	/* preview popup shows only the article: no full-bleed chrome cluster */
	margin: 0 0 var(--space-4);
}

.article-slot :global(a){
	color:var(--article-anchor-color);
}

/* Body paragraphs: capped measure for legibility, even block spacing.
   Standalone paragraphs render as <p>; text that flows around inline links
   stays as loose nodes and inherits the article line-height. */
.article-slot :global(p){
	max-width: var(--prose-measure);
	margin-block: 0 var(--space-4);
	line-height: var(--leading-body);
}

/* Headings: stepped scale, tighter leading, generous space above. */
.article-slot :global(.heading){
	line-height: var(--leading-heading);
	font-weight: 600;
	margin-block: var(--space-5) var(--space-4);
}
.article-slot :global(h1.heading){ font-size: var(--text-h1); }
.article-slot :global(h2.heading){ font-size: var(--text-h2); }
.article-slot :global(h3.heading){ font-size: var(--text-h3); }
.article-slot :global(h4.heading),
.article-slot :global(h5.heading),
.article-slot :global(h6.heading){ font-size: var(--text-h4); }

/* Lists: indent + the same block rhythm as paragraphs. */
.article-slot :global(ul),
.article-slot :global(ol){
	max-width: var(--prose-measure);
	margin-block: 0 var(--space-4);
	padding-left: var(--space-6);
	line-height: var(--leading-body);
}
.article-slot :global(li + li){
	margin-top: var(--space-1);
}

/* Inline code: subtle tinted chip, like GitHub. */
.article-slot :global(:not(pre) > code){
	padding: 0.15em 0.4em;
	font-size: 0.9em;
	background-color: var(--surface-2-bg);
	border-radius: var(--radius-sm);
}

/* Blockquotes: muted text behind an accent rule. */
.article-slot :global(blockquote){
	max-width: var(--prose-measure);
	margin-block: 0 var(--space-4);
	padding: 0 var(--space-4);
	color: var(--content-color-muted);
	border-left: 0.25em solid var(--soft-border-color);
}

.article-slot :global(.katex-display){
	max-width: 100%;
	overflow-x: auto;
	overflow-y: hidden;
	margin-block: var(--space-4);
	padding-bottom: 0.15rem;
}

/* --- Preview mode (page-render-preview plan, AD-002) ---------------------
   A previewed page (loaded in the hover popup/modal iframe) strips all site
   chrome and shows only the article. data-preview-mode is set by the inline
   head script above, before first paint. This also disables link_preview.js
   itself inside the frame (AD-005) — no-recursion by construction. */
:global(html[data-preview-mode="true"]) header,
:global(html[data-preview-mode="true"]) #wide-nav,
:global(html[data-preview-mode="true"]) #mobile-nav,
:global(html[data-preview-mode="true"]) #resize-left,
:global(html[data-preview-mode="true"]) #resize-right,
:global(html[data-preview-mode="true"]) #toc-nav-div,
:global(html[data-preview-mode="true"]) #mobile-nav-backdrop {
	display: none !important;
}

/* --- Hover-preview loading indicator (OP-001) -----------------------------
   Absolute-positioned like .external::after (Link.astro) so it never shifts
   surrounding text. reduced-motion is handled globally by tokens.css. */
.article-slot :global(a.link-preview-loading){
	position: relative;
}
.article-slot :global(a.link-preview-loading::after){
	content: "";
	position: absolute;
	top: 50%;
	right: -1.1em;
	width: 0.75em;
	height: 0.75em;
	margin-top: -0.375em;
	border-radius: 50%;
	border: 2px solid currentColor;
	border-top-color: transparent;
	opacity: 0.65;
	animation: link-preview-spin 0.7s linear infinite;
}
@keyframes link-preview-spin {
	to { transform: rotate(360deg); }
}

</style>

<script src="./menu_interactions_activation.js" />
{liveReload && <script src="./lazy_navigation.js" />}
{liveReload && <script src="./runtime_info.js" />}
<script src="./link_preview.js" />
