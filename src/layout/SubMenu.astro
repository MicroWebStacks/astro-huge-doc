---
import './colors.css';

export interface Props {
	items: Array<Object>;
    root?:boolean;
    level?:number;
    visibleLevel?: number;
    activePath?: Set<string>;
    forceVisible?: boolean;
    linkClass?: string;
}
const { items,root=true, level=1, visibleLevel = Number.POSITIVE_INFINITY, activePath, forceVisible = false, linkClass = '' } = Astro.props;
const nextLevel = level + 1;

// Indicator icons shown after a TOC label when its section contains a table,
// code block, diagram, or image. Inlined as SVG so they inherit the menu text color.
const tableIcon = `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18M3 15h18M9 3v18"/></svg>`;
const codeIcon = `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="8 7 3 12 8 17"/><polyline points="16 7 21 12 16 17"/><line x1="13" y1="5" x2="11" y2="19"/></svg>`;
const diagramIcon = `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="5" rx="1"/><rect x="14" y="16" width="7" height="5" rx="1"/><path d="M6.5 8v5a3 3 0 0 0 3 3H14"/></svg>`;
const imageIcon = `<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>`;
---
{items &&
    <ul class:list={[root?"root":"nested",{hidden:(!root && level > visibleLevel && !forceVisible)}]} data-level={level}>
        {items.map((item)=>(
            <li>
                <div class:list={[{entry_container:true, active:item.active, parent:item.parent, expanded:(item.parent && (nextLevel <= visibleLevel || forceVisible || activePath?.has(item.link??'')))}]} data-node-key={item.nodeKey ?? item.link ?? item.label}>
                    {item.parent &&
                        <span class="icon expand">
                            <svg viewBox="0 0 100 100" width="60" height="60" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M 20,10 L 70,50 L 20,90" stroke-width="20px" stroke="var(--menu-arrow-color)" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </span>
                    }
                    {Object.hasOwn(item,"link")?
                        <a  href={item.link} class:list={[linkClass]}>
                            <span class:list={["text href_hover",{parent:item.parent}]}>{item.label}</span>
                        </a>:
                        <span class:list={["text",{parent:item.parent}]}>{item.label}</span>
                    }
                    {item.hasTable &&
                        <span class="toc-mark" title="Section contains a table" set:html={tableIcon}></span>
                    }
                    {item.hasCode &&
                        <span class="toc-mark" title="Section contains a code block" set:html={codeIcon}></span>
                    }
                    {item.hasDiagram &&
                        <span class="toc-mark" title="Section contains a diagram" set:html={diagramIcon}></span>
                    }
                    {item.hasImage &&
                        <span class="toc-mark" title="Section contains an image" set:html={imageIcon}></span>
                    }
                </div>
                <Astro.self
                    items={item.items}
                    root={false}
                    level={level+1}
                    visibleLevel={visibleLevel}
                    activePath={activePath}
                    forceVisible={forceVisible || activePath?.has(item.link ?? '')}
                    linkClass={linkClass}
                />
            </li>
        ))}
    </ul>
}
<style>
    ul{
        display:flex;
        flex-direction: column;
        list-style: none;
        margin:0px;
        padding: 0px;
    }
    ul.nested{
        padding-left: var(--space-2);
        border-top:   0px;
        border-left:  1px solid var(--menu-border-left-color);
        border-right: 0px;
        border-bottom:0px;
        margin-left: var(--space-2);
        overflow: hidden;
        max-height: 200vh;
        transition-property: max-height;
        transition-duration: 0.4s;
    }
    ul.nested.hidden{
        max-height: 0px;
        transition-property: max-height;
        transition-duration: 0.4s;
    }
    li{
        min-width: 130px;
    }
    .entry_container{
        padding:0px;
        padding-left:0px;
        user-select: none;    
        color:var(--content-color);
        display:flex;
        align-items: center;
        min-height:2.25rem;
        font-size:var(--text-sm);
    }
    .entry_container>a{
        text-decoration: none;
        flex-grow: 1;
    }
    .entry_container>a:focus-visible{
        outline: 2px solid var(--front-blue);
        outline-offset: -2px;
    }
    /* active when nav menu item is matching url */
    .entry_container.active{
        background-color: var(--menu-active-color);
    }
    span.icon{
        padding:var(--space-1);
        padding-right:var(--space-1);
        flex-grow: 0;
    }
    span.text{
        padding:2px;
        padding-top:var(--space-1);
        padding-bottom:var(--space-1);
        color:var(--menu-text-color);
        display: block;
        flex-grow: 1;
        line-height:1.35;
    }
    span.text:not(.parent){
        padding:var(--space-3);
        padding-top:var(--space-1);
        padding-bottom:var(--space-1);
    }

    span.icon > svg{
        width:10px;
        height:10px;
        rotate: 0deg;
        transition: rotate .4s ease-in-out;
    }
    .entry_container.parent.expanded > span > svg{
        rotate: 90deg;
    }
    span.icon.expand:hover{
        background-color: var(--menu-span-hover-color);
        cursor: pointer;
    }
    span.text.href_hover:hover{
        background-color: var(--menu-span-hover-color);
    }
    /* table / diagram indicators shown after a toc label */
    span.toc-mark{
        flex-grow: 0;
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        padding: 0 2px;
        color: var(--menu-text-color);
        opacity: 0.55;
    }
    span.toc-mark:last-child{
        margin-right: var(--space-2);
    }

    /* scroll-spy cross-highlight: toc link matching the heading in view.
       Accent bar sits in a small gutter with a gap before the text (rather
       than an inset line flush against it). */
    a.toc_href.active > span.text{
        position: relative;
        background-color: var(--menu-active-color);
        color: var(--content-color);
        padding-left: var(--space-3);
    }
    a.toc_href.active > span.text::before{
        content: "";
        position: absolute;
        left: 3px;
        top: 0.15em;
        bottom: 0.15em;
        width: 3px;
        border-radius: 2px;
        background: var(--front-blue);
    }
    a.toc_href.hover > span.text{
        background-color: var(--menu-span-hover-color);
    }

</style>


<script src="./toc_menu_activation.js" />
