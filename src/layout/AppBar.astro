---
import './colors.css';
import Icon from "@/components/icon.astro"
import ThemeToggle from './ThemeToggle.astro';
import { buildAppBarMenu } from './layout_utils.js';

export interface Props {
    menu?: Array<{
        label: string;
        link: string;
        active_class?: string;
        align?: string;
        icon?: string;
    }>;
    showLeftToggle?: boolean;
    showRightToggle?: boolean;
}

const { menu: providedMenu = [], showLeftToggle = false, showRightToggle = false } = Astro.props as Props;
const menu = providedMenu.length ? providedMenu : buildAppBarMenu(Astro.url.pathname);
const left_side  = menu.filter((item)=>(!Object.hasOwn(item,"align") || !(item.align=="right")))
const right_side = menu.filter((item)=>(Object.hasOwn(item,"align") && (item.align=="right")))

---
<div class="navbar">
    <ul class="navbar-left">
        {showLeftToggle &&
            <li class="nav-toggle-item">
                <button id="nav-toggle-left" type="button" class="nav-toggle"
                    title="Toggle pages menu" aria-label="Toggle pages menu" aria-expanded="true">
                    <svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
                        <rect x="1.5" y="2.5" width="13" height="11" rx="1.6" fill="none" stroke="currentColor" stroke-width="1.3"></rect>
                        <line x1="6" y1="2.5" x2="6" y2="13.5" stroke="currentColor" stroke-width="1.3"></line>
                        <rect class="fill" x="2.7" y="4.2" width="2" height="7.6" rx="0.6" fill="currentColor"></rect>
                    </svg>
                </button>
            </li>
        }
        {left_side.map((item)=>(
        <li>
            <a href={item.link} class={item.active_class}>
                {item.label}
                {item.icon && <Icon filename={item.icon} />}
            </a>
        </li>
        ))}
    </ul>
    <ul class="navbar-right">
        {right_side.map((item)=>(
            <li>
                <a href={item.link} target={item.link.startsWith('/')?"":"_blank"}>
                    {item.icon && <Icon filename={item.icon} />}
                </a>
            </li>
        ))}
        <li class="theme-toggle-item">
            <ThemeToggle />
        </li>
        {showRightToggle &&
            <li class="nav-toggle-item">
                <button id="nav-toggle-right" type="button" class="nav-toggle"
                    title="Toggle outline" aria-label="Toggle outline" aria-expanded="true">
                    <svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
                        <rect x="1.5" y="2.5" width="13" height="11" rx="1.6" fill="none" stroke="currentColor" stroke-width="1.3"></rect>
                        <line x1="10" y1="2.5" x2="10" y2="13.5" stroke="currentColor" stroke-width="1.3"></line>
                        <rect class="fill" x="11.3" y="4.2" width="2" height="7.6" rx="0.6" fill="currentColor"></rect>
                    </svg>
                </button>
            </li>
        }
    </ul>
</div>

<style>
.navbar{
    display:flex;
    justify-content: space-between;
    min-width: 400px;
}
.navbar-left {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
}
.navbar-right {
    padding-right: 50px;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
}

ul{
    margin:0px;
}
li{
    list-style: none;
}

a{
    float:left;
    font-size: 17px;
    padding: 14px 16px;
    text-align:center;
    color: var(--content-color);
	text-decoration: none;

}
a:hover{
    background-color: var(--header-active-color);
}
a.active{
    border:0px;
    border-bottom:  3px solid var(--content-color-faint);
    background-color: var(--header-active-color);
}

.navbar-right > li > a{
    float:right;
    padding: 6px;
}
.theme-toggle-item{
    display:flex;
    align-items:center;
}

/* Side-menu toggles — the app bar is the single authority for opening and
   closing the page tree (left) and outline (right). */
.nav-toggle-item{
    display:flex;
    align-items:center;
}
.nav-toggle{
    display:flex;
    align-items:center;
    justify-content:center;
    background:transparent;
    border:0;
    border-radius:var(--radius-sm);
    margin:6px;
    padding:6px;
    color:var(--content-color-muted);
    cursor:pointer;
}
.nav-toggle:hover{
    background-color:var(--header-active-color);
    color:var(--content-color);
}
.nav-toggle:focus-visible{
    outline:2px solid var(--front-blue);
    outline-offset:2px;
}
/* Open state: accent the icon and light its sidebar cell so the button
   reads as "panel is showing". */
.nav-toggle[aria-expanded="true"]{
    color:var(--content-color);
}
.nav-toggle[aria-expanded="true"] .fill{
    fill:var(--front-blue);
}
.nav-toggle[aria-expanded="false"] .fill{
    opacity:0;
}
</style>
