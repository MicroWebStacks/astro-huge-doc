---
import './colors.css';
import Icon from "@/components/icon.astro"
import ThemeToggle from './ThemeToggle.astro';
import { buildAppBarMenu } from './layout_utils.js';
import { basePrefix } from '@/libs/blob-files.js';
import { config } from '@/config';

export interface Props {
    menu?: Array<{
        label: string;
        link: string;
        active_class?: string;
        align?: string;
        icon?: string;
    }>;
    showLeftToggle?: boolean;
    showRightToggle?: boolean;
    showRuntimeInfo?: boolean;
    exploreEnabled?: boolean;
    logPage?: { url: string; title: string } | null;
}

const { menu: providedMenu = [], showLeftToggle = false, showRightToggle = false, showRuntimeInfo = false, exploreEnabled = false, logPage = null } = Astro.props as Props;
const menu = providedMenu.length ? providedMenu : buildAppBarMenu(Astro.url.pathname);
const logHref = logPage ? `${basePrefix(config.base)}/${logPage.url}` : null;
const exploreHref = `${basePrefix(config.base)}/explore`;
const left_side  = menu.filter((item)=>(!Object.hasOwn(item,"align") || !(item.align=="right")))
const right_side = menu.filter((item)=>(Object.hasOwn(item,"align") && (item.align=="right")))

---
<div class="navbar">
    <ul class="navbar-left">
        {showLeftToggle &&
            <li class="nav-toggle-item">
                <button id="nav-toggle-left" type="button" class="nav-toggle"
                    title="Toggle pages menu" aria-label="Toggle pages menu" aria-expanded="false">
                    <svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
                        <rect x="1.5" y="2.5" width="13" height="11" rx="1.6" fill="none" stroke="currentColor" stroke-width="1.3"></rect>
                        <line x1="6" y1="2.5" x2="6" y2="13.5" stroke="currentColor" stroke-width="1.3"></line>
                        <rect class="fill" x="2.7" y="4.2" width="2" height="7.6" rx="0.6" fill="currentColor"></rect>
                    </svg>
                </button>
            </li>
        }
        {left_side.map((item)=>(
        <li>
            <a href={item.link} class={item.active_class}>
                {item.label}
                {item.icon && <Icon filename={item.icon} />}
            </a>
        </li>
        ))}
    </ul>
    <ul class="navbar-right">
        {right_side.map((item)=>(
            <li>
                <a href={item.link} target={item.link.startsWith('/')?"":"_blank"}>
                    {item.icon && <Icon filename={item.icon} />}
                </a>
            </li>
        ))}
        {logPage &&
            <li class="nav-toggle-item">
                <a class="nav-toggle log-link" href={logHref}
                    title={`Knowledge log: ${logPage.title}`} aria-label="Knowledge log">
                    <svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
                        <circle cx="8" cy="8" r="6.5" fill="none" stroke="currentColor" stroke-width="1.3"></circle>
                        <polyline points="8,4.6 8,8 10.6,9.6" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></polyline>
                    </svg>
                </a>
            </li>
        }
        {exploreEnabled &&
            <li class="nav-toggle-item">
                <a class="nav-toggle chrome-link" href={exploreHref}
                    title="Explore types, tags, and data issues" aria-label="Explore knowledge">
                    <svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
                        <circle cx="6.4" cy="6.4" r="4.4" fill="none" stroke="currentColor" stroke-width="1.3"></circle>
                        <line x1="9.7" y1="9.7" x2="13.7" y2="13.7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></line>
                        <circle cx="6.4" cy="6.4" r="1.2" fill="currentColor"></circle>
                    </svg>
                </a>
            </li>
        }
        {showRuntimeInfo &&
            <li class="nav-toggle-item">
                <button id="runtime-info-toggle" type="button" class="nav-toggle"
                    title="Preview runtime info" aria-label="Preview runtime info" aria-expanded="false">
                    <svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
                        <circle cx="8" cy="8" r="6.5" fill="none" stroke="currentColor" stroke-width="1.3"></circle>
                        <circle cx="8" cy="5" r="0.9" fill="currentColor"></circle>
                        <line x1="8" y1="7.4" x2="8" y2="11.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></line>
                    </svg>
                </button>
            </li>
        }
        <li class="theme-toggle-item">
            <ThemeToggle />
        </li>
        {showRightToggle &&
            <li class="nav-toggle-item">
                <button id="nav-toggle-right" type="button" class="nav-toggle"
                    title="Toggle outline" aria-label="Toggle outline" aria-expanded="false">
                    <svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
                        <rect x="1.5" y="2.5" width="13" height="11" rx="1.6" fill="none" stroke="currentColor" stroke-width="1.3"></rect>
                        <line x1="10" y1="2.5" x2="10" y2="13.5" stroke="currentColor" stroke-width="1.3"></line>
                        <rect class="fill" x="11.3" y="4.2" width="2" height="7.6" rx="0.6" fill="currentColor"></rect>
                    </svg>
                </button>
            </li>
        }
    </ul>
</div>

<style>
.navbar{
    display:flex;
    justify-content: space-between;
    min-width: 0;
}
.navbar-left {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
}
.navbar-right {
    padding-right: 0;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
}

ul{
    margin:0px;
    padding:0px;
}
li{
    list-style: none;
}

a{
    float:left;
    font-size: var(--text-base);
    padding: var(--space-3) var(--space-4);
    text-align:center;
    color: var(--content-color);
	text-decoration: none;

}
a:hover{
    background-color: var(--header-active-color);
}
a.active{
    border:0px;
    border-bottom:  3px solid var(--content-color-faint);
    background-color: var(--header-active-color);
}

.navbar-right > li > a{
    float:right;
    padding: var(--space-2);
}
.theme-toggle-item{
    display:flex;
    align-items:center;
}

/* Knowledge-log link (OKF plan DD-8): shares the toggle-button footprint but
   navigates instead of toggling; neutralize the generic app-bar <a> rules. */
a.log-link,
a.chrome-link{
    float:none;
    padding:var(--space-2);
}

/* Side-menu toggles — the app bar is the single authority for opening and
   closing the page tree (left) and outline (right). */
.nav-toggle-item{
    display:flex;
    align-items:center;
}
.nav-toggle{
    display:flex;
    align-items:center;
    justify-content:center;
    background:transparent;
    border:0;
    border-radius:var(--radius-sm);
    margin:var(--space-1) 2px;
    padding:var(--space-2);
    color:var(--content-color-muted);
    cursor:pointer;
    min-width:2.75rem;
    min-height:2.75rem;
}
.nav-toggle:hover{
    background-color:var(--header-active-color);
    color:var(--content-color);
}
.nav-toggle:focus-visible{
    outline:2px solid var(--front-blue);
    outline-offset:2px;
}
/* Open state: accent the icon and light its sidebar cell so the button
   reads as "panel is showing". */
.nav-toggle[aria-expanded="true"]{
    color:var(--content-color);
}
.nav-toggle[aria-expanded="true"] .fill{
    fill:var(--front-blue);
}
.nav-toggle[aria-expanded="false"] .fill{
    opacity:0;
}
@media only screen and (max-width: 700px) {
    a{
        padding-inline:var(--space-3);
    }
    .navbar-left,
    .navbar-right{
        flex-wrap:nowrap;
        min-width:0;
    }
    .nav-toggle{
        margin:0;
        min-width:44px;
        min-height:44px;
    }
}
</style>
