# MicroWebStacks — environment overrides (copy to `.env`).
#
# Precedence (highest wins):  root `.env`  >  shell/global env  >  manifest.yaml  >  defaults
# The root `.env` is loaded with override=true (see src/libs/load-env.js), so values
# here beat any ambient/global environment. NEVER commit a real `.env` — it is gitignored.
# Every value below is optional; the listed default applies when unset.
#
# Exception: a launcher that provides explicit runtime config (the VS Code
# extension) sets MICROWEBSTACKS_DOTENV_OVERRIDE=false, flipping precedence to
#   launcher env  >  `.env`  >  manifest.yaml  >  defaults
# so a previewed workspace's `.env` fills gaps but cannot clobber the preview's
# profile/port/paths. Relative paths here always resolve from the workspace root.

# --- Deployment profile / data backend -------------------------------------
# DOCS_PROFILE: 'full' = local website/warehouse (sqlite, native deps)
#               'lite' = VS Code extension engine (json, no native deps)
# DOCS_BACKEND: 'sqlite' | 'json'. If unset, derived from DOCS_PROFILE
#               (lite ⇒ json, otherwise sqlite).
DOCS_PROFILE=full
# DOCS_BACKEND=sqlite

# --- Diagram rendering (kroki) ---------------------------------------------
# Endpoint the engine POSTs diagram source to (no Java runs in VS Code).
# Default targets the dockerized kroki in compose.yaml (host port 18000).
# Corporate: set this to your internal kroki URL. Public opt-in: https://kroki.io
MICROWEBSTACKS_KROKI_SERVER=http://localhost:18000

# --- Server bind -----------------------------------------------------------
MICROWEBSTACKS_HOST=127.0.0.1
MICROWEBSTACKS_PORT=4321
MICROWEBSTACKS_PROTOCOL=http

# --- Paths -----------------------------------------------------------------
# SQLite content store (full profile). Relative paths resolve from the workspace root.
MICROWEBSTACKS_DB_PATH=dataset/content.db
# Markdown content root.
MICROWEBSTACKS_DOCS_ROOT=content

# --- Secrets (NEVER commit; `.env` only) -----------------------------------
# Used by scripts/fetch.js for authenticated GitHub access. Leave unset if unused.
# GITHUB_TOKEN=
